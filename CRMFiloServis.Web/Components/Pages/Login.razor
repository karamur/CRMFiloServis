@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using CRMFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IKullaniciService KullaniciService
@inject ILisansService LisansService
@inject NavigationManager Navigation
@inject AppAuthenticationStateProvider AuthProvider
@inject ProtectedLocalStorage LocalStorage
@rendermode InteractiveServer

<PageTitle>Giris - KoaFiloServis</PageTitle>

<div class="login-container">
    <div class="login-background">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <div class="login-card">
        <div class="login-header">
            <div class="logo-container">
                <i class="bi bi-truck"></i>
            </div>
            <h1><span class="brand-koa">Koa</span><span class="brand-filo">Filo</span><span class="brand-servis">Servis</span></h1>
            <p>Filo Yonetim &amp; Muhasebe Platformu</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger py-2 mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success py-2 mb-3">
                <i class="bi bi-check-circle me-2"></i>@successMessage
            </div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="GirisYapAsync" FormName="loginForm">
            <div class="mb-3">
                <label class="form-label">Kullanici Adi</label>
                <InputText @bind-Value="loginModel.KullaniciAdi" class="form-control form-control-lg" placeholder="Kullanici adinizi girin" />
            </div>

            <div class="mb-3 position-relative">
                <label class="form-label">Sifre</label>
                <input type="@(showPassword ? "text" : "password")" 
                       @bind="loginModel.Sifre" 
                       class="form-control form-control-lg" 
                       placeholder="Sifrenizi girin" />
                <span class="password-toggle" @onclick="() => showPassword = !showPassword">
                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                </span>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <InputCheckbox @bind-Value="loginModel.BeniHatirla" class="form-check-input" id="beniHatirla" />
                    <label class="form-check-label" for="beniHatirla">Beni Hatirla</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Giris Yapiliyor...</span>
                }
                else
                {
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    <span>Giris Yap</span>
                }
            </button>
        </EditForm>

        <div class="login-footer mt-4 text-center">
            <p class="text-muted small mb-0">v1.0.0 - KoaFiloServis</p>
        </div>
    </div>
</div>

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        position: relative;
        overflow: hidden;
    }

    .login-background {
        position: absolute;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.1;
        background: white;
    }

    .shape-1 { width: 400px; height: 400px; top: -100px; left: -100px; }
    .shape-2 { width: 300px; height: 300px; bottom: -50px; right: -50px; }
    .shape-3 { width: 200px; height: 200px; top: 50%; right: 20%; }

    .login-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        padding: 40px;
        width: 100%;
        max-width: 400px;
        position: relative;
        z-index: 10;
        margin: 20px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .logo-container {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
    }

    .logo-container i {
        font-size: 2rem;
        color: white;
    }

    .login-header h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .brand-koa { color: #1e3c72; font-weight: 800; }
    .brand-filo { color: #2a5298; font-weight: 700; }
    .brand-servis { color: #4a90d9; font-weight: 600; }

    .login-header p {
        color: #6c757d;
        font-size: 0.875rem;
    }

    .form-control-lg {
        padding: 12px 16px;
        font-size: 1rem;
        border-radius: 10px;
    }

    .password-toggle {
        position: absolute;
        right: 12px;
        top: 42px;
        cursor: pointer;
        color: #6c757d;
        padding: 5px;
    }

    .password-toggle:hover {
        color: #1e3c72;
    }

    .btn-primary {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(30, 60, 114, 0.4);
    }

    .form-check-input:checked {
        background-color: #1e3c72;
        border-color: #1e3c72;
    }
</style>

@code {
    private LoginModel loginModel = new();
    private bool showPassword = false;
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;

    private class LoginModel
    {
        public string KullaniciAdi { get; set; } = "";
        public string Sifre { get; set; } = "";
        public bool BeniHatirla { get; set; } = false;
    }

    private async Task GirisYapAsync()
    {
        if (string.IsNullOrWhiteSpace(loginModel.KullaniciAdi) || string.IsNullOrWhiteSpace(loginModel.Sifre))
        {
            errorMessage = "Kullanici adi ve sifre zorunludur!";
            return;
        }

        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var sonuc = await KullaniciService.GirisYapAsync(loginModel.KullaniciAdi, loginModel.Sifre);

            if (sonuc.Basarili)
            {
                successMessage = "Giris basarili! Yonlendiriliyorsunuz...";
                await Task.Delay(500);
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                errorMessage = sonuc.Mesaj ?? "Giris basarisiz!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Bir hata olustu: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
