@page "/"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using FaturaEntity = CRMFiloServis.Shared.Entities.Fatura
@inject ICariService CariService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IFaturaService FaturaService
@inject IServisCalismaService ServisCalismaService
@inject IBankaKasaHareketService BankaKasaService
@inject IBelgeUyariService BelgeUyariService
@inject IBudgetService BudgetService
@inject IKullaniciService KullaniciService
@inject NavigationManager Navigation
@inject ILogger<Home> Logger
@rendermode InteractiveServer

<PageTitle>CRM Filo Servis - Ana Sayfa</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else if (!HasDashboardPermission)
{
    <div class="container-fluid">
        <div class="alert alert-warning">
            <i class="bi bi-shield-lock me-2"></i>
            <strong>Dashboard görüntüleme yetkiniz bulunmuyor.</strong>
            <p class="mb-0 mt-2">Lütfen sistem yöneticinizle iletiţime geçin.</p>
        </div>
    </div>
}
else
{
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </h3>
        <small class="text-muted">Son güncelleme: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</small>
    </div>

    <!-- Kritik Uyarýlar Banner -->
    @if (CanViewBelgeUyarilari && belgeUyarilar != null && belgeUyarilar.ToplamKritikUyari > 0)
    {
        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
            <div class="flex-grow-1">
                <strong>@belgeUyarilar.ToplamKritikUyari kritik belge uyarýsý var!</strong>
                Süresi geçmiţ veya 7 gün içinde dolacak belgeler bulunuyor.
            </div>
            <button class="btn btn-outline-danger btn-sm" @onclick="() => showBelgeModal = true">
                <i class="bi bi-eye me-1"></i>Görüntüle
            </button>
        </div>
    }

    <!-- Özet Kartlar -->
    <div class="row mb-4">
        @if (CanViewCariler)
        {
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Toplam Cari</h6>
                            <h2>@cariSayisi</h2>
                        </div>
                        <i class="bi bi-people-fill" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/cariler" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }

        @if (CanViewAraclar)
        {
        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Aktif Araç</h6>
                            <h2>@aracSayisi</h2>
                        </div>
                        <i class="bi bi-truck" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/araclar" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }

        @if (CanViewSoforler)
        {
        <div class="col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Aktif Ţoför</h6>
                            <h2>@soforSayisi</h2>
                        </div>
                        <i class="bi bi-person-badge" style="font-size: 3rem, opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/soforler" class="text-dark text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }

        @if (CanViewFaturalar)
        {
        <div class="col-md-3">
            <div class="card bg-danger text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Bekleyen Fatura</h6>
                            <h2>@bekleyenFaturaSayisi</h2>
                        </div>
                        <i class="bi bi-receipt" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/faturalar" class="text-white text-decoration-none">
                        <small>Detaylar <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
        }
    </div>

    <!-- Finansal Özet -->
    @if (CanViewFinans)
    {
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Bu Ay Özet</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6 border-end">
                            <small class="text-muted d-block">Toplam Gelir</small>
                            <h5 class="text-success mb-0">@FormatKisa(buAyGelir)</h5>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Toplam Gider</small>
                            <h5 class="text-danger mb-0">@FormatKisa(buAyGider)</h5>
                        </div>
                    </div>
                    <hr />
                    <div class="text-center">
                        <small class="text-muted d-block">Net Kar/Zarar</small>
                        <h4 class="@(buAyGelir - buAyGider >= 0 ? "text-success" : "text-danger") mb-0">
                            @FormatKisa(buAyGelir - buAyGider)
                        </h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-bank me-2"></i>Kasa/Banka Durumu</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Toplam Kasa:</span>
                        <strong class="text-primary">@Format(toplamKasa)</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Toplam Banka:</span>
                        <strong class="text-primary">@Format(toplamBanka)</strong>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <span><strong>Genel Toplam:</strong></span>
                        <strong class="h5 text-success mb-0">@Format(toplamKasa + toplamBanka)</strong>
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/banka-kasa" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-arrow-right me-1"></i>Detay Görüntüle
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Bu Ay Bütçe</h6>
                </div>
                <div class="card-body">
                    @if (butceOzet != null)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Planlanan Ödeme:</span>
                            <strong class="text-danger">@FormatKisa(butceOzet.ToplamOdeme)</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Ödenen:</span>
                            <strong class="text-success">@FormatKisa(butceOzet.OdenenToplam)</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Bekleyen:</span>
                            <strong class="text-warning">@FormatKisa(butceOzet.BekleyenToplam)</strong>
                        </div>
                        <hr />
                        <div class="progress" style="height: 20px;">
                            @{
                                var odemeYuzdesi = butceOzet.ToplamOdeme > 0 
                                    ? (int)((butceOzet.OdenenToplam / butceOzet.ToplamOdeme) * 100) 
                                    : 0;
                            }
                            <div class="progress-bar bg-success" role="progressbar" 
                                 style="width: @odemeYuzdesi%" 
                                 aria-valuenow="@odemeYuzdesi" aria-valuemin="0" aria-valuemax="100">
                                @odemeYuzdesi%
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 text-center py-3">Bütçe verisi yok</p>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a href="/butce" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-arrow-right me-1"></i>Detay Görüntüle
                    </a>
                </div>
            </div>
        </div>
    </div>
    }

    <!-- Detay Kartlarý -->
    <div class="row mb-4">
        <!-- Vade Geçmiţ Faturalar -->
        @if (CanViewFaturalar)
        {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-exclamation-circle me-2"></i>Vade Geçmiţ Faturalar</h6>
                    <span class="badge bg-white text-danger">@vadeGecmisFaturalar.Count</span>
                </div>
                <div class="card-body" style="max-height: 300px; overflow-y: auto;">
                    @if (vadeGecmisFaturalar.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fatura No</th>
                                        <th>Cari</th>
                                        <th>Vade</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fatura in vadeGecmisFaturalar.Take(5))
                                    {
                                        <tr>
                                            <td>@fatura.FaturaNo</td>
                                            <td>@fatura.Cari?.Unvan</td>
                                            <td class="text-danger">@fatura.VadeTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td class="text-end"><strong>@FormatKisa(fatura.GenelToplam)</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (vadeGecmisFaturalar.Count > 5)
                        {
                            <div class="text-center mt-2">
                                <a href="/faturalar" class="btn btn-link btn-sm">+@(vadeGecmisFaturalar.Count - 5) fatura daha</a>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-success mb-0 text-center py-3">
                            <i class="bi bi-check-circle me-1"></i>Vade geçmiţ fatura yok
                        </p>
                    }
                </div>
            </div>
        </div>
        }

        <!-- Vade Yaklaţan Faturalar -->
        @if (CanViewFaturalar)
        {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-clock me-2"></i>Vade Yaklaţan Faturalar (7 gün)</h6>
                    <span class="badge bg-dark">@vadeYaklasanFaturalar.Count</span>
                </div>
                <div class="card-body" style="max-height: 300px; overflow-y: auto;">
                    @if (vadeYaklasanFaturalar.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fatura No</th>
                                        <th>Cari</th>
                                        <th>Vade</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fatura in vadeYaklasanFaturalar.Take(5))
                                    {
                                        <tr>
                                            <td>@fatura.FaturaNo</td>
                                            <td>@fatura.Cari?.Unvan</td>
                                            <td class="text-warning">@fatura.VadeTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td class="text-end"><strong>@FormatKisa(fatura.GenelToplam)</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 text-center py-3">Yaklaţan vade yok</p>
                    }
                </div>
            </div>
        </div>
        }
    </div>

    <!-- Son Ýţlemler -->
    <div class="row">
        @if (CanViewServisler)
        {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-calendar-check me-2"></i>Son Servis Çalýţmalarý</h6>
                    <a href="/servis-calismalari" class="btn btn-sm btn-outline-primary">Tümü</a>
                </div>
                <div class="card-body" style="max-height: 300px; overflow-y: auto;">
                    @if (sonCalismalar != null && sonCalismalar.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Araç</th>
                                        <th>Güzergah</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var calisma in sonCalismalar)
                                    {
                                        <tr>
                                            <td>@calisma.CalismaTarihi.ToString("dd.MM")</td>
                                            <td>@calisma.Arac?.AktifPlaka</td>
                                            <td>@calisma.Guzergah?.GuzergahAdi</td>
                                            <td class="text-end text-success"><strong>@FormatKisa(calisma.HesaplananFiyat)</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 text-center py-3">Henüz çalýţma bulunmuyor.</p>
                    }
                </div>
            </div>
        </div>
        }

        @if (CanViewFinans)
        {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Son Kasa/Banka Hareketleri</h6>
                    <a href="/banka-kasa" class="btn btn-sm btn-outline-primary">Tümü</a>
                </div>
                <div class="card-body" style="max-height: 300px; overflow-y: auto;">
                    @if (sonHareketler != null && sonHareketler.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Ýţlem</th>
                                        <th>Cari</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var hareket in sonHareketler)
                                    {
                                        <tr>
                                            <td>@hareket.IslemTarihi.ToString("dd.MM")</td>
                                            <td>
                                                <span class="badge @(hareket.HareketTipi == HareketTipi.Giris ? "bg-success" : "bg-danger")">
                                                    @(hareket.HareketTipi == HareketTipi.Giris ? "Tahsilat" : "Ödeme")
                                                </span>
                                            </td>
                                            <td>@hareket.Cari?.Unvan</td>
                                            <td class="text-end">
                                                <strong class="@(hareket.HareketTipi == HareketTipi.Giris ? "text-success" : "text-danger")">
                                                    @FormatKisa(hareket.Tutar)
                                                </strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 text-center py-3">Henüz hareket bulunmuyor.</p>
                    }
                </div>
            </div>
        </div>
        }
    </div>
</div>

<!-- Belge Uyarýlarý Modal -->
@if (showBelgeModal && belgeUyarilar != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-file-earmark-medical me-2"></i>Belge Süre Uyarýlarý
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showBelgeModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (belgeUyarilar.TumUyarilar.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Durum</th>
                                        <th>Belge Türü</th>
                                        <th>Ad / Plaka</th>
                                        <th>Bitiţ Tarihi</th>
                                        <th class="text-center">Kalan Gün</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var uyari in belgeUyarilar.TumUyarilar)
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi @uyari.Icon @(uyari.Seviye == BelgeUyariSeviye.Kritik ? "text-danger" : uyari.Seviye == BelgeUyariSeviye.Acil ? "text-warning" : "text-info")"></i>
                                            </td>
                                            <td>@uyari.BelgeTuru</td>
                                            <td><strong>@uyari.Baslik</strong></td>
                                            <td>@uyari.BitisTarihi.ToString("dd.MM.yyyy")</td>
                                            <td class="text-center">
                                                <span class="badge @(uyari.KalanGun < 0 ? "bg-danger" : uyari.KalanGun <= 7 ? "bg-warning text-dark" : "bg-info")">
                                                    @(uyari.KalanGun < 0 ? $"{Math.Abs(uyari.KalanGun)} gün geçti" : $"{uyari.KalanGun} gün")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-success py-4">
                            <i class="bi bi-check-circle" style="font-size: 3rem;"></i>
                            <p class="mb-0 mt-2">Tüm belgeler güncel!</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showBelgeModal = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}
}

@code {
    private int cariSayisi = 0;
    private int aracSayisi = 0;
    private int soforSayisi = 0;
    private int bekleyenFaturaSayisi = 0;

    private decimal buAyGelir = 0;
    private decimal buAyGider = 0;
    private decimal toplamKasa = 0;
    private decimal toplamBanka = 0;

    private List<ServisCalisma>? sonCalismalar;
    private List<FaturaEntity> vadeGecmisFaturalar = new();
    private List<FaturaEntity> vadeYaklasanFaturalar = new();
    private List<BankaKasaHareket>? sonHareketler;
    
    private BelgeUyariOzet? belgeUyarilar;
    private BudgetOzet? butceOzet;
    private bool showBelgeModal = false;
    private bool isLoading = true;
    private static readonly SemaphoreSlim _semaphore = new(1, 1);
    
    // Yetki kontrolleri
    private HashSet<string> kullaniciYetkileri = new();
    private bool HasDashboardPermission => kullaniciYetkileri.Contains("Dashboard.Goruntule") || kullaniciYetkileri.Contains("*");
    private bool CanViewCariler => kullaniciYetkileri.Contains("Cari.Goruntule") || kullaniciYetkileri.Contains("*");
    private bool CanViewAraclar => kullaniciYetkileri.Contains("Arac.Goruntule") || kullaniciYetkileri.Contains("*");
    private bool CanViewSoforler => kullaniciYetkileri.Contains("Sofor.Goruntule") || kullaniciYetkileri.Contains("*");
    private bool CanViewFaturalar => kullaniciYetkileri.Contains("Fatura.Goruntule") || kullaniciYetkileri.Contains("*");
    private bool CanViewFinans => kullaniciYetkileri.Contains("Finans.Goruntule") || kullaniciYetkileri.Contains("*");
    private bool CanViewServisler => kullaniciYetkileri.Contains("ServisCalisma.Goruntule") || kullaniciYetkileri.Contains("*");
    private bool CanViewBelgeUyarilari => kullaniciYetkileri.Contains("BelgeUyari.Goruntule") || kullaniciYetkileri.Contains("*");

    protected override async Task OnInitializedAsync()
    {
        await LoadYetkilerAsync();
        
        if (HasDashboardPermission)
        {
            await LoadDashboardDataAsync();
        }
        else
        {
            isLoading = false;
        }
    }
    
    private async Task LoadYetkilerAsync()
    {
        try
        {
            kullaniciYetkileri = await KullaniciService.GetCurrentUserYetkilerAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Yetki yükleme hatasý");
            kullaniciYetkileri = new HashSet<string>();
        }
    }

    private async Task LoadDashboardDataAsync()
    {
        if (!await _semaphore.WaitAsync(0))
            return;

        try
        {
            isLoading = true;
            StateHasChanged();

            if (CanViewCariler)
            {
                cariSayisi = await CariService.GetCountAsync();
                await Task.Delay(10);
            }
            
            if (CanViewAraclar)
            {
                aracSayisi = await AracService.GetActiveCountAsync();
                await Task.Delay(10);
            }
            
            if (CanViewSoforler)
            {
                soforSayisi = await SoforService.GetActiveCountAsync();
                await Task.Delay(10);
            }
            
            if (CanViewFaturalar)
            {
                var faturaStats = await FaturaService.GetDashboardStatsAsync();
                bekleyenFaturaSayisi = faturaStats.BekleyenFaturaSayisi;
                buAyGelir = faturaStats.BuAyGelir;
                buAyGider = faturaStats.BuAyGider;
                vadeGecmisFaturalar = faturaStats.VadeGecmisFaturalar;
                vadeYaklasanFaturalar = faturaStats.VadeYaklasanFaturalar;
                await Task.Delay(10);
            }

            if (CanViewFinans)
            {
                var bankaStats = await BankaKasaService.GetDashboardStatsAsync();
                toplamKasa = bankaStats.ToplamKasa;
                toplamBanka = bankaStats.ToplamBanka;
                await Task.Delay(10);
                
                sonHareketler = await BankaKasaService.GetRecentAsync(5);
                await Task.Delay(10);
                
                butceOzet = await BudgetService.GetAylikOzetAsync(DateTime.Today.Year, DateTime.Today.Month);
                await Task.Delay(10);
            }

            if (CanViewServisler)
            {
                sonCalismalar = await ServisCalismaService.GetRecentAsync(5);
                await Task.Delay(10);
            }
            
            if (CanViewBelgeUyarilari)
            {
                belgeUyarilar = await BelgeUyariService.GetBelgeUyarilarAsync(30);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Dashboard yükleme hatasý");
        }
        finally
        {
            isLoading = false;
            _semaphore.Release();
            StateHasChanged();
        }
    }
}
