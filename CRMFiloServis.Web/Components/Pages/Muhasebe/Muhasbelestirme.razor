@page "/muhasebe/muhasbelestirme"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using CRMFiloServis.Web.Models
@inject IMuhasebeService MuhasebeService
@inject IJSRuntime JS
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Fatura/Masraf Muhasebeleştirme</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-journal-check me-2"></i>Fatura/Masraf Muhasebeleştirme</h3>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Yükleniyor...</p>
        </div>
    }
    else
    {
        <!-- Özet Kartları -->
        @if (durum != null)
        {
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card border-warning">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0 text-muted">Bekleyen Fatura</h6>
                            <h3 class="mb-0 text-warning">@durum.BekleyenFatura</h3>
                            <small class="text-muted">@durum.BekleyenFaturaTutar.ToString("N2") ₺</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-success">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0 text-muted">İşlenmiş Fatura</h6>
                            <h3 class="mb-0 text-success">@durum.MuhasbelestirilmisFatura</h3>
                            <small class="text-muted">/ @durum.ToplamFatura toplam</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-warning">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0 text-muted">Bekleyen Masraf</h6>
                            <h3 class="mb-0 text-warning">@durum.BekleyenMasraf</h3>
                            <small class="text-muted">@durum.BekleyenMasrafTutar.ToString("N2") ₺</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-success">
                        <div class="card-body text-center py-2">
                            <h6 class="mb-0 text-muted">İşlenmiş Masraf</h6>
                            <h3 class="mb-0 text-success">@durum.MuhasbelestirilmisMasraf</h3>
                            <small class="text-muted">/ @durum.ToplamMasraf toplam</small>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Filtreler -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small">Başlangıç Tarihi</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtreBaslangic" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Bitiş Tarihi</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtreBitis" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Fatura Yönü</label>
                        <select class="form-select form-select-sm" @bind="filtreFaturaYonu">
                            <option value="">Tümü</option>
                            <option value="Giden">Giden Faturalar</option>
                            <option value="Gelen">Gelen Faturalar</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-primary btn-sm" @onclick="FiltreleVeYenile">
                            <i class="bi bi-search me-1"></i>Filtrele
                        </button>
                        <button class="btn btn-outline-secondary btn-sm ms-1" @onclick="FiltreTemizle">
                            <i class="bi bi-x-circle me-1"></i>Temizle
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sekme Navigasyonu -->
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button class="nav-link @(aktifSekme == "fatura" ? "active" : "")" @onclick='() => SekmeSecimi("fatura")'>
                    <i class="bi bi-receipt me-1"></i>Faturalar
                    @if (bekleyenFaturalar.Count > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">@bekleyenFaturalar.Count</span>
                    }
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(aktifSekme == "masraf" ? "active" : "")" @onclick='() => SekmeSecimi("masraf")'>
                    <i class="bi bi-cash-stack me-1"></i>Masraflar
                    @if (bekleyenMasraflar.Count > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">@bekleyenMasraflar.Count</span>
                    }
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(aktifSekme == "islenmis" ? "active" : "")" @onclick='() => SekmeSecimi("islenmis")'>
                    <i class="bi bi-check-circle me-1 text-success"></i>İşlenmiş Kayıtlar
                    @if (islenmisSayisi > 0)
                    {
                        <span class="badge bg-success ms-1">@islenmisSayisi</span>
                    }
                </button>
            </li>
        </ul>

        <!-- FATURA SEKMESİ -->
        @if (aktifSekme == "fatura")
        {
            @if (bekleyenFaturalar.Count == 0)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>Muhasebeleştirilmemiş fatura bulunmamaktadır.
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <button class="btn btn-sm btn-outline-primary" @onclick="TumFaturalariSec">
                            <i class="bi bi-check-all me-1"></i>Tümünü Seç
                        </button>
                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="TumFaturalariKaldir">
                            <i class="bi bi-x-lg me-1"></i>Seçimi Kaldır
                        </button>
                        <span class="text-muted ms-2">@seciliFaturaCount / @bekleyenFaturalar.Count seçili</span>
                    </div>
                    <div class="d-flex gap-1">
                        <button class="btn btn-outline-info btn-sm" @onclick="FaturaKontrolYap" disabled="@(seciliFaturaCount == 0 || isIslemYapiliyor)">
                            <i class="bi bi-clipboard-check me-1"></i>Kontrol Et
                        </button>
                        <button class="btn btn-outline-success btn-sm" @onclick="FaturaExcelExport" disabled="@(seciliFaturaCount == 0)">
                            <i class="bi bi-file-earmark-excel me-1"></i>Excel
                        </button>
                        <button class="btn btn-success" @onclick="SeciliFaturalariMuhasbelestir"
                                disabled="@(seciliFaturaCount == 0 || isIslemYapiliyor)">
                            @if (isIslemYapiliyor && aktifSekme == "fatura")
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-journal-check me-1"></i>Muhasebeleştir (@seciliFaturaCount)
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center" style="width:40px;">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@tumFaturalarSecili"
                                           @onchange="ToggleTumFaturalar" />
                                </th>
                                <th>Fatura No</th>
                                <th>Tarih</th>
                                <th>Cari</th>
                                <th class="text-center">Yön</th>
                                <th class="text-end">Ara Toplam</th>
                                <th class="text-end">KDV</th>
                                <th class="text-end">Genel Toplam</th>
                                <th class="text-center">Tevkifat</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fatura in bekleyenFaturalar)
                            {
                                <tr class="@(fatura.Secildi ? "table-info" : "")">
                                    <td class="text-center">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@fatura.Secildi"
                                               @onchange="() => ToggleFaturaSecim(fatura)" />
                                    </td>
                                    <td><strong>@fatura.FaturaNo</strong></td>
                                    <td>@fatura.FaturaTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>@fatura.CariUnvan</td>
                                    <td class="text-center">
                                        <span class="badge @(fatura.FaturaYonu == "Giden" ? "bg-primary" : "bg-info")">
                                            @fatura.FaturaYonu
                                        </span>
                                    </td>
                                    <td class="text-end">@fatura.AraToplam.ToString("N2") ₺</td>
                                    <td class="text-end">@fatura.KdvTutar.ToString("N2") ₺</td>
                                    <td class="text-end"><strong>@fatura.GenelToplam.ToString("N2") ₺</strong></td>
                                    <td class="text-center">
                                        @if (fatura.TevkifatliMi)
                                        {
                                            <span class="badge bg-warning text-dark" title="Tevkifat: @fatura.TevkifatTutar.ToString("N2") ₺">
                                                <i class="bi bi-exclamation-triangle"></i>
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary fw-bold">
                                <td colspan="5" class="text-end">Seçili Toplam:</td>
                                <td class="text-end">@seciliFaturaAraToplam.ToString("N2") ₺</td>
                                <td class="text-end">@seciliFaturaKdvToplam.ToString("N2") ₺</td>
                                <td class="text-end">@seciliFaturaGenelToplam.ToString("N2") ₺</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        }

        <!-- MASRAF SEKMESİ -->
        @if (aktifSekme == "masraf")
        {
            @if (bekleyenMasraflar.Count == 0)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>Muhasebeleştirilmemiş masraf bulunmamaktadır.
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <button class="btn btn-sm btn-outline-primary" @onclick="TumMasraflariSec">
                            <i class="bi bi-check-all me-1"></i>Tümünü Seç
                        </button>
                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="TumMasraflariKaldir">
                            <i class="bi bi-x-lg me-1"></i>Seçimi Kaldır
                        </button>
                        <span class="text-muted ms-2">@seciliMasrafCount / @bekleyenMasraflar.Count seçili</span>
                    </div>
                    <div class="d-flex gap-1">
                        <button class="btn btn-outline-info btn-sm" @onclick="MasrafKontrolYap" disabled="@(seciliMasrafCount == 0 || isIslemYapiliyor)">
                            <i class="bi bi-clipboard-check me-1"></i>Kontrol Et
                        </button>
                        <button class="btn btn-outline-success btn-sm" @onclick="MasrafExcelExport" disabled="@(seciliMasrafCount == 0)">
                            <i class="bi bi-file-earmark-excel me-1"></i>Excel
                        </button>
                        <button class="btn btn-success" @onclick="SeciliMasraflariMuhasbelestir"
                                disabled="@(seciliMasrafCount == 0 || isIslemYapiliyor)">
                            @if (isIslemYapiliyor && aktifSekme == "masraf")
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-journal-check me-1"></i>Muhasebeleştir (@seciliMasrafCount)
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center" style="width:40px;">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@tumMasraflarSecili"
                                           @onchange="ToggleTumMasraflar" />
                                </th>
                                <th>Tarih</th>
                                <th>Araç</th>
                                <th>Masraf Kalemi</th>
                                <th>Kategori</th>
                                <th class="text-end">Tutar</th>
                                <th>Belge No</th>
                                <th>Muhatap</th>
                                <th>Açıklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var masraf in bekleyenMasraflar)
                            {
                                <tr class="@(masraf.Secildi ? "table-info" : "")">
                                    <td class="text-center">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@masraf.Secildi"
                                               @onchange="() => ToggleMasrafSecim(masraf)" />
                                    </td>
                                    <td>@masraf.MasrafTarihi.ToString("dd.MM.yyyy")</td>
                                    <td><strong>@masraf.AracPlaka</strong></td>
                                    <td>@masraf.MasrafKalemi</td>
                                    <td>
                                        <span class="badge bg-secondary">@masraf.MasrafKategori</span>
                                    </td>
                                    <td class="text-end"><strong>@masraf.Tutar.ToString("N2") ₺</strong></td>
                                    <td>@masraf.BelgeNo</td>
                                    <td>@(masraf.CariUnvan ?? masraf.SoforAd ?? "-")</td>
                                    <td><small>@masraf.Aciklama</small></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary fw-bold">
                                <td colspan="5" class="text-end">Seçili Toplam:</td>
                                <td class="text-end">@seciliMasrafToplam.ToString("N2") ₺</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        }

        <!-- İŞLENMİŞ KAYITLAR SEKMESİ -->
        @if (aktifSekme == "islenmis")
        {
            @if (islenmisLoading)
            {
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary"></div>
                    <span class="ms-2">Yükleniyor...</span>
                </div>
            }
            else if (islenmisKayitlar.Count == 0)
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>Seçili tarih aralığında muhasebeleştirilmiş kayıt bulunmamaktadır.
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <select class="form-select form-select-sm d-inline-block" style="width: auto;" @bind="islenmisFiltreTip">
                            <option value="">Tümü</option>
                            <option value="Fatura">Faturalar</option>
                            <option value="Masraf">Masraflar</option>
                        </select>
                        <button class="btn btn-sm btn-outline-primary ms-1" @onclick="TumIslenmisleriSec">
                            <i class="bi bi-check-all me-1"></i>Tümünü Seç
                        </button>
                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="TumIslenmisleriKaldir">
                            <i class="bi bi-x-lg me-1"></i>Kaldır
                        </button>
                        <span class="text-muted ms-2">@seciliIslenmisCount seçili</span>
                    </div>
                    <button class="btn btn-outline-danger btn-sm" @onclick="SecilileriGeriAl"
                            disabled="@(seciliIslenmisCount == 0 || isIslemYapiliyor)">
                        @if (isIslemYapiliyor && aktifSekme == "islenmis")
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Geri Al (@seciliIslenmisCount)
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center" style="width:40px;">
                                    <input type="checkbox" class="form-check-input" @onchange="ToggleTumIslenmisler" />
                                </th>
                                <th>Tip</th>
                                <th>Kaynak No</th>
                                <th>Kaynak Tarih</th>
                                <th>Cari / Muhatap</th>
                                <th class="text-end">Tutar</th>
                                <th>Fiş No</th>
                                <th>Fiş Tarihi</th>
                                <th>Açıklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kayit in FiltrelenmisIslenmisler())
                            {
                                <tr class="@(kayit.Secildi ? "table-info" : "")">
                                    <td class="text-center">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@kayit.Secildi"
                                               @onchange="() => kayit.Secildi = !kayit.Secildi" />
                                    </td>
                                    <td>
                                        <span class="badge @(kayit.KaynakTip == "Fatura" ? "bg-primary" : "bg-info")">
                                            @kayit.KaynakTip
                                        </span>
                                    </td>
                                    <td><strong>@kayit.KaynakNo</strong></td>
                                    <td>@kayit.KaynakTarih.ToString("dd.MM.yyyy")</td>
                                    <td>@(kayit.CariUnvan ?? "-")</td>
                                    <td class="text-end"><strong>@kayit.Tutar.ToString("N2") ₺</strong></td>
                                    <td>
                                        <a href="/muhasebe/fis/@kayit.FisId" class="text-decoration-none">@kayit.FisNo</a>
                                    </td>
                                    <td>@(kayit.FisTarihi != DateTime.MinValue ? kayit.FisTarihi.ToString("dd.MM.yyyy") : "-")</td>
                                    <td><small>@kayit.Aciklama</small></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary fw-bold">
                                <td colspan="5" class="text-end">Toplam:</td>
                                <td class="text-end">@FiltrelenmisIslenmisler().Sum(k => k.Tutar).ToString("N2") ₺</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        }
    }
</div>

<!-- Kontrol Listesi Modalı -->
@if (kontrolModal && kontrolSonuc != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header @(kontrolSonuc.HataSayisi > 0 ? "bg-danger" : kontrolSonuc.UyariSayisi > 0 ? "bg-warning" : "bg-success") text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-clipboard-check me-2"></i>Muhasebeleştirme Kontrol Listesi
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => kontrolModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row text-center mb-3">
                        <div class="col-4">
                            <div class="card border-danger">
                                <div class="card-body py-2">
                                    <h4 class="text-danger mb-0">@kontrolSonuc.HataSayisi</h4>
                                    <small>Hata</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card border-warning">
                                <div class="card-body py-2">
                                    <h4 class="text-warning mb-0">@kontrolSonuc.UyariSayisi</h4>
                                    <small>Uyarı</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card border-info">
                                <div class="card-body py-2">
                                    <h4 class="text-info mb-0">@kontrolSonuc.BilgiSayisi</h4>
                                    <small>Bilgi</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @foreach (var madde in kontrolSonuc.Maddeler)
                    {
                        <div class="alert @GetKontrolAlertClass(madde.Seviye) py-2 mb-2">
                            <div class="d-flex align-items-start">
                                <i class="bi @GetKontrolIcon(madde.Seviye) me-2 mt-1"></i>
                                <div>
                                    <strong>@madde.Baslik</strong>
                                    <div class="small">@madde.Aciklama</div>
                                    @if (!string.IsNullOrEmpty(madde.IlgiliKayit))
                                    {
                                        <div class="small text-muted mt-1">
                                            <i class="bi bi-link-45deg me-1"></i>@madde.IlgiliKayit
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if (!kontrolSonuc.HazirMi)
                    {
                        <div class="alert alert-danger mt-3">
                            <i class="bi bi-exclamation-octagon me-2"></i>
                            <strong>Kritik hatalar mevcut!</strong> Muhasebeleştirme öncesi hataları giderin.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => kontrolModal = false">Kapat</button>
                    @if (kontrolSonuc.HazirMi)
                    {
                        <button class="btn btn-success" @onclick="KontroldenMuhasbelestir">
                            <i class="bi bi-journal-check me-1"></i>Devam Et - Muhasebeleştir
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Sonuç Modalı -->
@if (sonucModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header @(sonuc?.HataliSayisi > 0 ? "bg-warning" : "bg-success") text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-journal-check me-2"></i>Muhasebeleştirme Sonucu
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="SonucModalKapat"></button>
                </div>
                <div class="modal-body">
                    @if (sonuc != null)
                    {
                        <div class="row text-center mb-3">
                            <div class="col-6">
                                <div class="card border-success">
                                    <div class="card-body py-2">
                                        <h3 class="text-success mb-0">@sonuc.BasariliSayisi</h3>
                                        <small>Başarılı</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card border-danger">
                                    <div class="card-body py-2">
                                        <h3 class="text-danger mb-0">@sonuc.HataliSayisi</h3>
                                        <small>Hatalı</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (sonuc.Hatalar.Count > 0)
                        {
                            <div class="alert alert-danger">
                                <h6><i class="bi bi-exclamation-triangle me-1"></i>Hatalar:</h6>
                                <ul class="mb-0 small">
                                    @foreach (var hata in sonuc.Hatalar)
                                    {
                                        <li>@hata</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (sonuc.BasariliSayisi > 0)
                        {
                            <div class="alert alert-success">
                                <i class="bi bi-check-circle me-1"></i>
                                @sonuc.BasariliSayisi adet muhasebe fişi başarıyla oluşturuldu.
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SonucModalKapat">Tamam</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Bildirim Toast -->
@if (!string.IsNullOrEmpty(bildirimMesaj))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert">
            <div class="toast-header @(bildirimBasarili ? "bg-success" : "bg-danger") text-white">
                <i class="bi @(bildirimBasarili ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                <strong class="me-auto">@(bildirimBasarili ? "Başarılı" : "Hata")</strong>
                <button type="button" class="btn-close btn-close-white" @onclick="() => bildirimMesaj = null"></button>
            </div>
            <div class="toast-body">
                @bildirimMesaj
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isIslemYapiliyor = false;
    private bool islenmisLoading = false;
    private string aktifSekme = "fatura";

    private MuhasbelestirmeDurum? durum;
    private List<MuhasebeFaturaOzet> bekleyenFaturalar = new();
    private List<MuhasebeMasrafOzet> bekleyenMasraflar = new();

    // İşlenmiş kayıtlar
    private List<MuhasbelestirilmisKayit> islenmisKayitlar = new();
    private string islenmisFiltreTip = "";
    private int islenmisSayisi;

    // Filtre
    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;
    private string filtreFaturaYonu = "";

    // Kontrol modal
    private bool kontrolModal = false;
    private MuhasbelestirmeKontrol? kontrolSonuc;
    private string kontrolKaynak = ""; // "fatura" veya "masraf"

    // Sonuç modal
    private bool sonucModal = false;
    private MuhasbelestirmeSonuc? sonuc;

    // Bildirim
    private string? bildirimMesaj;
    private bool bildirimBasarili;
    private System.Threading.Timer? bildirimTimer;

    // Hesaplanan
    private int seciliFaturaCount => bekleyenFaturalar.Count(f => f.Secildi);
    private decimal seciliFaturaAraToplam => bekleyenFaturalar.Where(f => f.Secildi).Sum(f => f.AraToplam);
    private decimal seciliFaturaKdvToplam => bekleyenFaturalar.Where(f => f.Secildi).Sum(f => f.KdvTutar);
    private decimal seciliFaturaGenelToplam => bekleyenFaturalar.Where(f => f.Secildi).Sum(f => f.GenelToplam);
    private bool tumFaturalarSecili => bekleyenFaturalar.Count > 0 && bekleyenFaturalar.All(f => f.Secildi);

    private int seciliMasrafCount => bekleyenMasraflar.Count(m => m.Secildi);
    private decimal seciliMasrafToplam => bekleyenMasraflar.Where(m => m.Secildi).Sum(m => m.Tutar);
    private bool tumMasraflarSecili => bekleyenMasraflar.Count > 0 && bekleyenMasraflar.All(m => m.Secildi);

    private int seciliIslenmisCount => islenmisKayitlar.Count(k => k.Secildi);

    protected override async Task OnInitializedAsync()
    {
        await YenileData();
    }

    private async Task YenileData()
    {
        isLoading = true;
        try
        {
            durum = await MuhasebeService.GetMuhasbelestirmeDurumuAsync();

            FaturaYonu? faturaYonuFilter = filtreFaturaYonu switch
            {
                "Giden" => FaturaYonu.Giden,
                "Gelen" => FaturaYonu.Gelen,
                _ => null
            };

            bekleyenFaturalar = await MuhasebeService.GetMuhasbelestirilmemisFaturalarAsync(
                filtreBaslangic, filtreBitis, faturaYonuFilter);

            bekleyenMasraflar = await MuhasebeService.GetMuhasbelestirilmemisMasraflarAsync(
                filtreBaslangic, filtreBitis);

            islenmisSayisi = (durum?.MuhasbelestirilmisFatura ?? 0) + (durum?.MuhasbelestirilmisMasraf ?? 0);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task IslenmisKayitlariYukle()
    {
        islenmisLoading = true;
        try
        {
            islenmisKayitlar = await MuhasebeService.GetMuhasbelestirilmisKayitlarAsync(
                filtreBaslangic, filtreBitis);
        }
        finally
        {
            islenmisLoading = false;
        }
    }

    private async Task FiltreleVeYenile()
    {
        await YenileData();
        if (aktifSekme == "islenmis")
            await IslenmisKayitlariYukle();
    }

    private async Task FiltreTemizle()
    {
        filtreBaslangic = null;
        filtreBitis = null;
        filtreFaturaYonu = "";
        await YenileData();
        if (aktifSekme == "islenmis")
            await IslenmisKayitlariYukle();
    }

    private async Task SekmeSecimi(string sekme)
    {
        aktifSekme = sekme;
        if (sekme == "islenmis" && islenmisKayitlar.Count == 0)
            await IslenmisKayitlariYukle();
    }

    // Fatura seçim işlemleri
    private void ToggleFaturaSecim(MuhasebeFaturaOzet fatura) => fatura.Secildi = !fatura.Secildi;
    private void TumFaturalariSec() { foreach (var f in bekleyenFaturalar) f.Secildi = true; }
    private void TumFaturalariKaldir() { foreach (var f in bekleyenFaturalar) f.Secildi = false; }
    private void ToggleTumFaturalar()
    {
        var hedef = !tumFaturalarSecili;
        foreach (var f in bekleyenFaturalar) f.Secildi = hedef;
    }

    // Masraf seçim işlemleri
    private void ToggleMasrafSecim(MuhasebeMasrafOzet masraf) => masraf.Secildi = !masraf.Secildi;
    private void TumMasraflariSec() { foreach (var m in bekleyenMasraflar) m.Secildi = true; }
    private void TumMasraflariKaldir() { foreach (var m in bekleyenMasraflar) m.Secildi = false; }
    private void ToggleTumMasraflar()
    {
        var hedef = !tumMasraflarSecili;
        foreach (var m in bekleyenMasraflar) m.Secildi = hedef;
    }

    // İşlenmiş kayıt seçim
    private void TumIslenmisleriSec() { foreach (var k in FiltrelenmisIslenmisler()) k.Secildi = true; }
    private void TumIslenmisleriKaldir() { foreach (var k in islenmisKayitlar) k.Secildi = false; }
    private void ToggleTumIslenmisler()
    {
        var hedef = !islenmisKayitlar.All(k => k.Secildi);
        foreach (var k in FiltrelenmisIslenmisler()) k.Secildi = hedef;
    }

    private List<MuhasbelestirilmisKayit> FiltrelenmisIslenmisler()
    {
        if (string.IsNullOrEmpty(islenmisFiltreTip))
            return islenmisKayitlar;
        return islenmisKayitlar.Where(k => k.KaynakTip == islenmisFiltreTip).ToList();
    }

    // Kontrol işlemleri
    private async Task FaturaKontrolYap()
    {
        var seciliIdler = bekleyenFaturalar.Where(f => f.Secildi).Select(f => f.FaturaId).ToList();
        if (seciliIdler.Count == 0) return;

        kontrolKaynak = "fatura";
        kontrolSonuc = await MuhasebeService.KontrolYapAsync(faturaIdleri: seciliIdler);
        kontrolModal = true;
    }

    private async Task MasrafKontrolYap()
    {
        var seciliIdler = bekleyenMasraflar.Where(m => m.Secildi).Select(m => m.MasrafId).ToList();
        if (seciliIdler.Count == 0) return;

        kontrolKaynak = "masraf";
        kontrolSonuc = await MuhasebeService.KontrolYapAsync(masrafIdleri: seciliIdler);
        kontrolModal = true;
    }

    private async Task KontroldenMuhasbelestir()
    {
        kontrolModal = false;
        if (kontrolKaynak == "fatura")
            await SeciliFaturalariMuhasbelestir();
        else if (kontrolKaynak == "masraf")
            await SeciliMasraflariMuhasbelestir();
    }

    // Excel Export
    private async Task FaturaExcelExport()
    {
        var seciliIdler = bekleyenFaturalar.Where(f => f.Secildi).Select(f => f.FaturaId).ToList();
        if (seciliIdler.Count == 0) return;

        try
        {
            var bytes = await MuhasebeService.ExportMuhasbelestirmeKontrolExcelAsync(faturaIdleri: seciliIdler);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"Fatura_Kontrol_{DateTime.Now:yyyyMMdd}.xlsx", base64);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Excel export hatası: {ex.Message}", false);
        }
    }

    private async Task MasrafExcelExport()
    {
        var seciliIdler = bekleyenMasraflar.Where(m => m.Secildi).Select(m => m.MasrafId).ToList();
        if (seciliIdler.Count == 0) return;

        try
        {
            var bytes = await MuhasebeService.ExportMuhasbelestirmeKontrolExcelAsync(masrafIdleri: seciliIdler);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"Masraf_Kontrol_{DateTime.Now:yyyyMMdd}.xlsx", base64);
        }
        catch (Exception ex)
        {
            BildirimGoster($"Excel export hatası: {ex.Message}", false);
        }
    }

    // Toplu muhasebeleştirme
    private async Task SeciliFaturalariMuhasbelestir()
    {
        var seciliIdler = bekleyenFaturalar.Where(f => f.Secildi).Select(f => f.FaturaId).ToList();
        if (seciliIdler.Count == 0) return;

        isIslemYapiliyor = true;
        try
        {
            sonuc = await MuhasebeService.TopluFaturaMuhasbelestirAsync(seciliIdler);
            sonucModal = true;
            await YenileData();
        }
        catch (Exception ex)
        {
            BildirimGoster($"İşlem hatası: {ex.Message}", false);
        }
        finally
        {
            isIslemYapiliyor = false;
        }
    }

    private async Task SeciliMasraflariMuhasbelestir()
    {
        var seciliIdler = bekleyenMasraflar.Where(m => m.Secildi).Select(m => m.MasrafId).ToList();
        if (seciliIdler.Count == 0) return;

        isIslemYapiliyor = true;
        try
        {
            sonuc = await MuhasebeService.TopluMasrafMuhasbelestirAsync(seciliIdler);
            sonucModal = true;
            await YenileData();
        }
        catch (Exception ex)
        {
            BildirimGoster($"İşlem hatası: {ex.Message}", false);
        }
        finally
        {
            isIslemYapiliyor = false;
        }
    }

    // Geri alma
    private async Task SecilileriGeriAl()
    {
        var seciliFisIdler = islenmisKayitlar
            .Where(k => k.Secildi && k.FisId > 0)
            .Select(k => k.FisId)
            .Distinct()
            .ToList();

        if (seciliFisIdler.Count == 0) return;

        isIslemYapiliyor = true;
        try
        {
            sonuc = await MuhasebeService.TopluGeriAlAsync(seciliFisIdler);
            sonucModal = true;
            await YenileData();
            await IslenmisKayitlariYukle();
        }
        catch (Exception ex)
        {
            BildirimGoster($"Geri alma hatası: {ex.Message}", false);
        }
        finally
        {
            isIslemYapiliyor = false;
        }
    }

    private void SonucModalKapat()
    {
        sonucModal = false;
        sonuc = null;
    }

    // Yardımcı metotlar
    private static string GetKontrolAlertClass(KontrolSeviye seviye) => seviye switch
    {
        KontrolSeviye.Hata => "alert-danger",
        KontrolSeviye.Uyari => "alert-warning",
        _ => "alert-info"
    };

    private static string GetKontrolIcon(KontrolSeviye seviye) => seviye switch
    {
        KontrolSeviye.Hata => "bi-x-circle-fill text-danger",
        KontrolSeviye.Uyari => "bi-exclamation-triangle-fill text-warning",
        _ => "bi-info-circle-fill text-info"
    };

    private void BildirimGoster(string mesaj, bool basarili)
    {
        bildirimMesaj = mesaj;
        bildirimBasarili = basarili;
        bildirimTimer?.Dispose();
        bildirimTimer = new System.Threading.Timer(_ =>
        {
            bildirimMesaj = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose()
    {
        bildirimTimer?.Dispose();
    }
}
