@page "/butce"
@page "/butce/{Yil:int}/{Ay:int}"
@using CRMFiloServis.Shared.Entities
@using CRMFiloServis.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IBudgetService BudgetService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Butce Analiz</PageTitle>

<div class="container-fluid">
    <!-- Ust Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-2">
            @if (secilenGun.HasValue)
            {
                <button class="btn btn-outline-secondary" @onclick="GeriDon">
                    <i class="bi bi-arrow-left me-1"></i>Geri
                </button>
                <h4 class="mb-0"><i class="bi bi-calendar-day me-2"></i>@secilenGunTarih.ToString("dd MMMM yyyy")</h4>
            }
            else
            {
                <h3 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Butce Analiz</h3>
            }
        </div>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 100px;" @bind="secilenYil" @bind:after="YenileDataAsync">
                @for (int y = DateTime.Today.Year + 2; y >= DateTime.Today.Year - 5; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select" style="width: 130px;" @bind="secilenAy" @bind:after="YenileDataAsync">
                <option value="0">Tum Yil</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@GetAyAdi(m)</option>
                }
            </select>
            <div class="btn-group">
                <button class="btn btn-outline-success" @onclick="ExcelSablonIndir" title="Excel Sablon Indir">
                    <i class="bi bi-download"></i>
                </button>
                <button class="btn btn-outline-success" @onclick="() => showExcelImportModal = true" title="Excel Yukle">
                    <i class="bi bi-upload"></i>
                </button>
            </div>
            <button class="btn btn-primary" @onclick="YeniOdemeAc">
                <i class="bi bi-plus-lg me-1"></i>Yeni
            </button>
            <button class="btn btn-success" @onclick="TaksitliOdemeAc">
                <i class="bi bi-calendar-plus me-1"></i>Taksitli
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Ozet Kartlari -->
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small>Toplam</small>
                                <h4 class="mb-0">@FormatPara(ozet?.ToplamOdeme ?? 0)</h4>
                            </div>
                            <i class="bi bi-cash-stack" style="font-size: 2rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white h-100">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small>Odenen</small>
                                <h4 class="mb-0">@FormatPara(ozet?.OdenenToplam ?? 0)</h4>
                            </div>
                            <i class="bi bi-check-circle" style="font-size: 2rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark h-100">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small>Bekleyen</small>
                                <h4 class="mb-0">@FormatPara(ozet?.BekleyenToplam ?? 0)</h4>
                            </div>
                            <i class="bi bi-clock" style="font-size: 2rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white h-100">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small>Kredi Taksit</small>
                                <h4 class="mb-0">@FormatPara(krediTaksitToplam)</h4>
                            </div>
                            <i class="bi bi-credit-card" style="font-size: 2rem; opacity: 0.5;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Sol: Takvim -->
            <div class="col-md-5">
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                        <h6 class="mb-0"><i class="bi bi-calendar3 me-2"></i>@GetAyAdi(aktifTakvimAy) @secilenYil</h6>
                        @if (secilenAy == 0)
                        {
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary btn-sm" @onclick="OncekiAy" disabled="@(aktifTakvimAy <= 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <button class="btn btn-outline-primary btn-sm" @onclick="SonrakiAy" disabled="@(aktifTakvimAy >= 12)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <div class="card-body p-2">
                        <table class="table table-bordered table-sm mb-0" style="table-layout: fixed;">
                            <thead>
                                <tr class="text-center bg-light">
                                    <th>Pzt</th><th>Sal</th><th>Car</th><th>Per</th><th>Cum</th><th>Cmt</th><th>Paz</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var ilkGun = new DateTime(secilenYil, aktifTakvimAy, 1);
                                    var ilkGunHafta = ((int)ilkGun.DayOfWeek + 6) % 7;
                                    var gunSayisi = DateTime.DaysInMonth(secilenYil, aktifTakvimAy);
                                    var satirSayisi = (int)Math.Ceiling((ilkGunHafta + gunSayisi) / 7.0);
                                    var gun = 1;
                                }
                                @for (int satir = 0; satir < satirSayisi; satir++)
                                {
                                    <tr>
                                        @for (int sutun = 0; sutun < 7; sutun++)
                                        {
                                            var hucreIndex = satir * 7 + sutun;
                                            if (hucreIndex < ilkGunHafta || gun > gunSayisi)
                                            {
                                                <td class="bg-light"></td>
                                            }
                                            else
                                            {
                                                var currentGun = gun;
                                                var gunData = takvimData?.FirstOrDefault(t => t.Gun == currentGun);
                                                var bugun = DateTime.Today.Day == currentGun && DateTime.Today.Month == aktifTakvimAy && DateTime.Today.Year == secilenYil;
                                                var seciliMi = secilenGun == currentGun;
                                                <td class="@(seciliMi ? "bg-primary text-white" : bugun ? "bg-info bg-opacity-25 border-info" : "") p-1" 
                                                    style="height: 60px; vertical-align: top; cursor: pointer;" 
                                                    @onclick="() => GunSec(currentGun)">
                                                    <div class="d-flex justify-content-between">
                                                        <strong class="@(seciliMi ? "" : bugun ? "text-info" : "")">@currentGun</strong>
                                                        @if (gunData?.OdemeSayisi > 0)
                                                        {
                                                            <span class="badge @(seciliMi ? "bg-light text-primary" : "bg-danger") rounded-pill" style="font-size: 0.65rem;">@gunData.OdemeSayisi</span>
                                                        }
                                                    </div>
                                                    @if (gunData?.ToplamOdeme > 0)
                                                    {
                                                        <div class="small @(seciliMi ? "" : "text-danger")" style="font-size: 0.7rem;">
                                                            @FormatPara(gunData.ToplamOdeme)
                                                        </div>
                                                    }
                                                </td>
                                                gun++;
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Kredi Taksit Filtresi -->
                <div class="card">
                    <div class="card-header py-2">
                        <h6 class="mb-0"><i class="bi bi-credit-card me-2"></i>Kredi Taksitleri</h6>
                    </div>
                    <div class="card-body py-2">
                        <div class="d-flex gap-2 mb-2">
                            <select class="form-select form-select-sm" @bind="krediFiltre" @bind:after="KrediFiltreUygula">
                                <option value="tum">Tum Odemeler</option>
                                <option value="kredi">Sadece Kredi/Taksit</option>
                                <option value="normal">Sadece Normal</option>
                            </select>
                        </div>
                        @if (aktifKrediler.Any())
                        {
                            <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                                @foreach (var kredi in aktifKrediler.Take(5))
                                {
                                    <div class="list-group-item list-group-item-action p-2" style="cursor: pointer;" @onclick="() => KrediSec(kredi)">
                                        <div class="d-flex justify-content-between">
                                            <small><strong>@kredi.MasrafKalemi</strong></small>
                                            <span class="badge bg-warning text-dark">@kredi.KalanTaksitSayisi/@kredi.ToplamTaksitSayisi</span>
                                        </div>
                                        <div class="progress mt-1" style="height: 4px;">
                                            <div class="progress-bar bg-success" style="width: @kredi.TamamlanmaYuzdesi%"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <small class="text-muted">Aktif kredi bulunmuyor</small>
                        }
                    </div>
                </div>
            </div>

            <!-- Sag: Liste ve Detay -->
            <div class="col-md-7">
                @if (secilenGun.HasValue)
                {
                    <!-- Gun Detay Listesi -->
                    <div class="card">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">
                                <i class="bi bi-list-ul me-2"></i>@secilenGunTarih.ToString("dd MMMM yyyy") - @secilenGunOdemeleri.Count Odeme
                            </h6>
                            <span class="badge bg-danger">Toplam: @FormatPara(secilenGunOdemeleri.Sum(o => o.Miktar))</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                @foreach (var odeme in secilenGunOdemeleri)
                                {
                                    <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => OdemeDetayAc(odeme)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>@odeme.MasrafKalemi</strong>
                                                @if (!string.IsNullOrEmpty(odeme.Aciklama))
                                                {
                                                    <br /><small class="text-muted">@odeme.Aciklama</small>
                                                }
                                                @if (odeme.TaksitliMi)
                                                {
                                                    <br /><span class="badge bg-info">Taksit @odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi</span>
                                                }
                                            </div>
                                            <div class="text-end">
                                                <strong class="text-danger">@FormatPara(odeme.Miktar)</strong>
                                                <br /><span class="badge @GetDurumClass(odeme.Durum)">@GetDurumAdi(odeme.Durum)</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (!secilenGunOdemeleri.Any())
                                {
                                    <div class="list-group-item text-center text-muted py-4">
                                        <i class="bi bi-calendar-x" style="font-size: 2rem;"></i>
                                        <p class="mb-0 mt-2">Bu gunde odeme bulunmuyor</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Normal Liste -->
                    <div class="card mb-3">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Odeme Listesi</h6>
                            <span class="badge bg-secondary">@filtrelenmisOdemeler.Count kayit</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Masraf</th>
                                            <th class="text-end">Tutar</th>
                                            <th class="text-center">Durum</th>
                                            <th class="text-center">Islem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var odeme in filtrelenmisOdemeler.Take(50))
                                        {
                                            <tr style="cursor: pointer;" @onclick="() => OdemeDetayAc(odeme)">
                                                <td>
                                                    <small>@odeme.OdemeTarihi.ToString("dd.MM")</small>
                                                    @if (odeme.TaksitliMi)
                                                    {
                                                        <span class="badge bg-info ms-1" style="font-size: 0.6rem;">T</span>
                                                    }
                                                </td>
                                                <td>
                                                    <strong>@odeme.MasrafKalemi</strong>
                                                    @if (odeme.TaksitliMi)
                                                    {
                                                        <small class="text-muted"> (@odeme.KacinciTaksit/@odeme.ToplamTaksitSayisi)</small>
                                                    }
                                                </td>
                                                <td class="text-end"><strong>@FormatPara(odeme.Miktar)</strong></td>
                                                <td class="text-center">
                                                    <span class="badge @GetDurumClass(odeme.Durum)" style="font-size: 0.65rem;">@GetDurumAdi(odeme.Durum)</span>
                                                </td>
                                                <td class="text-center">
                                                    @if (odeme.Durum == OdemeDurum.Bekliyor)
                                                    {
                                                        <button class="btn btn-success btn-sm py-0" @onclick:stopPropagation="true" @onclick="() => OdendiIsaretle(odeme)">
                                                            <i class="bi bi-check"></i>
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Dinamik Grafik -->
                    <div class="card">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Harcama Grafigi</h6>
                            <div class="btn-group btn-group-sm">
                                <button class="btn @(grafikTip == "aylik" ? "btn-primary" : "btn-outline-primary")" @onclick="GrafikAylikSec">Aylik</button>
                                <button class="btn @(grafikTip == "kategori" ? "btn-primary" : "btn-outline-primary")" @onclick="GrafikKategoriSec">Kategori</button>
                            </div>
                        </div>
                        <div class="card-body">
                            <canvas id="dinamikChart" style="height: 180px;"></canvas>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Odeme Detay Modal -->
@if (showOdemeDetayModal && detayOdeme != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Odeme Detayi</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-borderless">
                        <tr><th width="120">Tarih:</th><td>@detayOdeme.OdemeTarihi.ToString("dd.MM.yyyy")</td></tr>
                        <tr><th>Masraf:</th><td><strong>@detayOdeme.MasrafKalemi</strong></td></tr>
                        <tr><th>Aciklama:</th><td>@(detayOdeme.Aciklama ?? "-")</td></tr>
                        <tr><th>Tutar:</th><td><strong class="text-danger fs-5">@FormatPara(detayOdeme.Miktar)</strong></td></tr>
                        <tr><th>Durum:</th><td><span class="badge @GetDurumClass(detayOdeme.Durum)">@GetDurumAdi(detayOdeme.Durum)</span></td></tr>
                        @if (detayOdeme.TaksitliMi)
                        {
                            <tr><th>Taksit:</th><td><span class="badge bg-info">@detayOdeme.KacinciTaksit / @detayOdeme.ToplamTaksitSayisi</span></td></tr>
                            <tr><th>Kalan:</th><td>@detayOdeme.KalanTaksitSayisi taksit</td></tr>
                        }
                        @if (!string.IsNullOrEmpty(detayOdeme.Notlar))
                        {
                            <tr><th>Notlar:</th><td>@detayOdeme.Notlar</td></tr>
                        }
                    </table>
                </div>
                <div class="modal-footer">
                    @if (detayOdeme.Durum == OdemeDurum.Bekliyor)
                    {
                        <button class="btn btn-success" @onclick="() => OdendiIsaretle(detayOdeme)">
                            <i class="bi bi-check-lg me-1"></i>Odendi Isaretle
                        </button>
                    }
                    <button class="btn btn-primary" @onclick="() => OdemeDuzenle(detayOdeme)">
                        <i class="bi bi-pencil me-1"></i>Duzenle
                    </button>
                    <button class="btn btn-outline-danger" @onclick="() => OdemeSil(detayOdeme)">
                        <i class="bi bi-trash me-1"></i>Sil
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Yeni/Duzenle Odeme Modal -->
@if (showOdemeModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editOdeme.Id > 0 ? "Odeme Duzenle" : "Yeni Odeme")</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Odeme Tarihi *</label>
                        <input type="date" class="form-control" @bind="editOdeme.OdemeTarihi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Masraf Kalemi *</label>
                        <input type="text" class="form-control" @bind="editOdeme.MasrafKalemi" list="masrafKalemleri" />
                        <datalist id="masrafKalemleri">
                            @foreach (var kalem in masrafKalemleri)
                            {
                                <option value="@kalem.KalemAdi" />
                            }
                        </datalist>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <input type="text" class="form-control" @bind="editOdeme.Aciklama" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Miktar *</label>
                        <div class="input-group">
                            <input type="number" class="form-control" @bind="editOdeme.Miktar" step="0.01" />
                            <span class="input-group-text">TL</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Durum</label>
                        <select class="form-select" @bind="editOdeme.Durum">
                            <option value="@OdemeDurum.Bekliyor">Bekliyor</option>
                            <option value="@OdemeDurum.Odendi">Odendi</option>
                            <option value="@OdemeDurum.Ertelendi">Ertelendi</option>
                            <option value="@OdemeDurum.Iptal">Iptal</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notlar</label>
                        <textarea class="form-control" rows="2" @bind="editOdeme.Notlar"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="OdemeKaydet">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Taksitli Odeme Modal -->
@if (showTaksitModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Taksitli Odeme</h5>
                    <button type="button" class="btn-close" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Baslangic Tarihi *</label>
                                <input type="date" class="form-control" @bind="taksitRequest.BaslangicTarihi" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Taksit Sayisi *</label>
                                <input type="number" class="form-control" @bind="taksitRequest.TaksitSayisi" min="2" max="60" @bind:after="TaksitOnizlemeGuncelle" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Masraf Kalemi *</label>
                        <input type="text" class="form-control" @bind="taksitRequest.MasrafKalemi" list="masrafKalemleri2" />
                        <datalist id="masrafKalemleri2">
                            @foreach (var kalem in masrafKalemleri)
                            {
                                <option value="@kalem.KalemAdi" />
                            }
                        </datalist>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <input type="text" class="form-control" @bind="taksitRequest.Aciklama" />
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Toplam Tutar *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="taksitRequest.ToplamTutar" step="0.01" @bind:after="TaksitOnizlemeGuncelle" />
                                    <span class="input-group-text">TL</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Taksit Tutari</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" value="@(taksitRequest.TaksitSayisi > 0 ? (taksitRequest.ToplamTutar / taksitRequest.TaksitSayisi).ToString("N2") : "0")" readonly />
                                    <span class="input-group-text">TL</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Iptal</button>
                    <button type="button" class="btn btn-primary" @onclick="TaksitliOdemeKaydet">
                        <i class="bi bi-calendar-plus me-1"></i>@taksitRequest.TaksitSayisi Taksit Olustur
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Excel Import Modal -->
@if (showExcelImportModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Excel Yukle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ModalKapat"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Excel Dosyasi Secin</label>
                        <InputFile OnChange="ExcelDosyaYukle" accept=".xls,.xlsx" class="form-control" />
                    </div>
                    @if (isImporting)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border text-success" role="status"></div>
                            <p class="mt-2">Yukleniyor...</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-success" @onclick="ExcelSablonIndir">
                        <i class="bi bi-download me-1"></i>Sablon Indir
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ModalKapat">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Yil { get; set; }
    [Parameter] public int Ay { get; set; }

    private int secilenYil;
    private int secilenAy;
    private int aktifTakvimAy;
    private int? secilenGun = null;
    private DateTime secilenGunTarih;
    private bool isLoading = true;
    private bool isImporting = false;
    private string krediFiltre = "tum";
    private string grafikTip = "aylik";

    private BudgetOzet? ozet;
    private BudgetYillikOzet? yillikOzet;
    private List<BudgetOdeme> odemeler = new();
    private List<BudgetOdeme> filtrelenmisOdemeler = new();
    private List<BudgetOdeme> secilenGunOdemeleri = new();
    private List<BudgetGunlukOzet>? takvimData;
    private List<BudgetKategoriOzet>? kategoriOzet;
    private List<BudgetMasrafKalemi> masrafKalemleri = new();
    private List<KrediOzet> aktifKrediler = new();
    private decimal krediTaksitToplam = 0;

    // Modals
    private bool showOdemeModal = false;
    private bool showOdemeDetayModal = false;
    private bool showTaksitModal = false;
    private bool showExcelImportModal = false;

    private BudgetOdeme editOdeme = new();
    private BudgetOdeme? detayOdeme;
    private TaksitliOdemeRequest taksitRequest = new();

    private static readonly string[] AyAdlari = { "", "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", 
                                                   "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };

    protected override async Task OnInitializedAsync()
    {
        secilenYil = Yil > 0 ? Yil : DateTime.Today.Year;
        secilenAy = Ay > 0 ? Ay : DateTime.Today.Month;
        aktifTakvimAy = secilenAy > 0 ? secilenAy : DateTime.Today.Month;

        await LoadMasrafKalemleriAsync();
        await YenileDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !secilenGun.HasValue)
        {
            await RenderChartAsync();
        }
    }

    private async Task LoadMasrafKalemleriAsync()
    {
        masrafKalemleri = await BudgetService.GetMasrafKalemleriAsync();
    }

    private async Task YenileDataAsync()
    {
        isLoading = true;
        secilenGun = null;
        StateHasChanged();

        try
        {
            odemeler = await BudgetService.GetOdemelerAsync(secilenYil, secilenAy > 0 ? secilenAy : null);
            yillikOzet = await BudgetService.GetYillikOzetAsync(secilenYil);
            aktifKrediler = await BudgetService.GetAktifKredilerAsync();

            // Kredi taksit toplami
            krediTaksitToplam = odemeler.Where(o => o.TaksitliMi).Sum(o => o.Miktar);

            if (secilenAy > 0)
            {
                aktifTakvimAy = secilenAy;
                ozet = await BudgetService.GetAylikOzetAsync(secilenYil, secilenAy);
                takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, secilenAy);
            }
            else
            {
                ozet = new BudgetOzet
                {
                    Yil = secilenYil,
                    ToplamOdeme = yillikOzet.ToplamOdeme,
                    OdenenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Odendi).Sum(o => o.Miktar),
                    BekleyenToplam = odemeler.Where(o => o.Durum == OdemeDurum.Bekliyor).Sum(o => o.Miktar),
                    ToplamKayit = odemeler.Count,
                    OdenenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Odendi),
                    BekleyenKayit = odemeler.Count(o => o.Durum == OdemeDurum.Bekliyor)
                };
                takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy);
            }

            kategoriOzet = await BudgetService.GetKategoriOzetAsync(secilenYil, secilenAy > 0 ? secilenAy : null);
            KrediFiltreUygula();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void KrediFiltreUygula()
    {
        filtrelenmisOdemeler = krediFiltre switch
        {
            "kredi" => odemeler.Where(o => o.TaksitliMi).OrderBy(o => o.OdemeTarihi).ToList(),
            "normal" => odemeler.Where(o => !o.TaksitliMi).OrderBy(o => o.OdemeTarihi).ToList(),
            _ => odemeler.OrderBy(o => o.OdemeTarihi).ToList()
        };
        StateHasChanged();
    }

    private async Task RenderChartAsync()
    {
        try
        {
            if (grafikTip == "aylik" && yillikOzet != null)
            {
                var aylar = yillikOzet.AylikToplamlar.Select(a => GetAyAdi(a.Ay).Substring(0, 3)).ToArray();
                var toplamlar = yillikOzet.AylikToplamlar.Select(a => (double)a.Toplam).ToArray();
                await JS.InvokeVoidAsync("createBarChart", "dinamikChart", aylar, toplamlar, new double[12], "Harcama", "");
            }
            else if (grafikTip == "kategori" && kategoriOzet != null && kategoriOzet.Any())
            {
                var labels = kategoriOzet.Take(6).Select(k => k.MasrafKalemi).ToArray();
                var data = kategoriOzet.Take(6).Select(k => (double)k.Toplam).ToArray();
                var colors = kategoriOzet.Take(6).Select(k => k.Renk ?? "#6c757d").ToArray();
                await JS.InvokeVoidAsync("createDoughnutChart", "dinamikChart", labels, data, colors);
            }
        }
        catch { }
    }

    private async Task GrafikAylikSec()
    {
        grafikTip = "aylik";
        StateHasChanged();
        await Task.Delay(100);
        await RenderChartAsync();
    }

    private async Task GrafikKategoriSec()
    {
        grafikTip = "kategori";
        StateHasChanged();
        await Task.Delay(100);
        await RenderChartAsync();
    }

    private async Task GrafikTipDegistir(string tip)
    {
        grafikTip = tip;
        StateHasChanged();
        await Task.Delay(100);
        await RenderChartAsync();
    }

    private async Task OncekiAy()
    {
        if (aktifTakvimAy > 1)
        {
            aktifTakvimAy--;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy);
            secilenGun = null;
            StateHasChanged();
        }
    }

    private async Task SonrakiAy()
    {
        if (aktifTakvimAy < 12)
        {
            aktifTakvimAy++;
            takvimData = await BudgetService.GetTakvimDataAsync(secilenYil, aktifTakvimAy);
            secilenGun = null;
            StateHasChanged();
        }
    }

    private void GunSec(int gun)
    {
        secilenGun = gun;
        secilenGunTarih = new DateTime(secilenYil, aktifTakvimAy, gun);
        var gunData = takvimData?.FirstOrDefault(t => t.Gun == gun);
        secilenGunOdemeleri = gunData?.Odemeler ?? new();
        StateHasChanged();
    }

    private void GeriDon()
    {
        secilenGun = null;
        secilenGunOdemeleri.Clear();
        StateHasChanged();
    }

    private void OdemeDetayAc(BudgetOdeme odeme)
    {
        detayOdeme = odeme;
        showOdemeDetayModal = true;
    }

    private void KrediSec(KrediOzet kredi)
    {
        krediFiltre = "kredi";
        filtrelenmisOdemeler = odemeler
            .Where(o => o.TaksitGrupId == kredi.TaksitGrupId)
            .OrderBy(o => o.OdemeTarihi)
            .ToList();
        StateHasChanged();
    }

    private void YeniOdemeAc()
    {
        editOdeme = new BudgetOdeme
        {
            OdemeTarihi = secilenGun.HasValue ? secilenGunTarih : DateTime.Today,
            Durum = OdemeDurum.Bekliyor
        };
        showOdemeModal = true;
    }

    private void OdemeDuzenle(BudgetOdeme odeme)
    {
        editOdeme = new BudgetOdeme
        {
            Id = odeme.Id,
            OdemeTarihi = odeme.OdemeTarihi,
            MasrafKalemi = odeme.MasrafKalemi,
            Aciklama = odeme.Aciklama,
            Miktar = odeme.Miktar,
            Durum = odeme.Durum,
            Notlar = odeme.Notlar,
            TaksitliMi = odeme.TaksitliMi,
            ToplamTaksitSayisi = odeme.ToplamTaksitSayisi,
            KacinciTaksit = odeme.KacinciTaksit,
            TaksitGrupId = odeme.TaksitGrupId
        };
        showOdemeDetayModal = false;
        showOdemeModal = true;
    }

    private async Task OdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(editOdeme.MasrafKalemi) || editOdeme.Miktar <= 0)
        {
            ToastService.ShowWarning("Masraf kalemi ve miktar zorunludur!");
            return;
        }

        try
        {
            if (editOdeme.Id > 0)
            {
                await BudgetService.UpdateOdemeAsync(editOdeme);
                ToastService.ShowSuccess("Odeme guncellendi.");
            }
            else
            {
                await BudgetService.CreateOdemeAsync(editOdeme);
                ToastService.ShowSuccess("Odeme eklendi.");
            }

            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task OdendiIsaretle(BudgetOdeme odeme)
    {
        odeme.Durum = OdemeDurum.Odendi;
        await BudgetService.UpdateOdemeAsync(odeme);
        ToastService.ShowSuccess($"{odeme.MasrafKalemi} odendi.");
        showOdemeDetayModal = false;
        await YenileDataAsync();
    }

    private async Task OdemeSil(BudgetOdeme odeme)
    {
        await BudgetService.DeleteOdemeAsync(odeme.Id);
        ToastService.ShowSuccess("Odeme silindi.");
        showOdemeDetayModal = false;
        await YenileDataAsync();
    }

    private void TaksitliOdemeAc()
    {
        taksitRequest = new TaksitliOdemeRequest
        {
            BaslangicTarihi = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
            TaksitSayisi = 12
        };
        showTaksitModal = true;
    }

    private void TaksitOnizlemeGuncelle() { }

    private async Task TaksitliOdemeKaydet()
    {
        if (string.IsNullOrWhiteSpace(taksitRequest.MasrafKalemi) || taksitRequest.ToplamTutar <= 0 || taksitRequest.TaksitSayisi < 2)
        {
            ToastService.ShowWarning("Tum alanlari doldurun!");
            return;
        }

        try
        {
            await BudgetService.CreateTaksitliOdemeAsync(taksitRequest);
            ToastService.ShowSuccess($"{taksitRequest.TaksitSayisi} taksit olusturuldu.");
            ModalKapat();
            await YenileDataAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private void ModalKapat()
    {
        showOdemeModal = false;
        showOdemeDetayModal = false;
        showTaksitModal = false;
        showExcelImportModal = false;
    }

    private string GetAyAdi(int ay) => AyAdlari[ay];

    private int GetKalanGun()
    {
        var bugun = DateTime.Today;
        var aktifAy = secilenAy > 0 ? secilenAy : bugun.Month;
        if (bugun.Year != secilenYil || bugun.Month != aktifAy) return 0;
        return DateTime.DaysInMonth(secilenYil, aktifAy) - bugun.Day;
    }

    private string GetDurumAdi(OdemeDurum durum) => durum switch
    {
        OdemeDurum.Bekliyor => "Bekliyor",
        OdemeDurum.Odendi => "Odendi",
        OdemeDurum.Iptal => "Iptal",
        OdemeDurum.Ertelendi => "Ertelendi",
        _ => durum.ToString()
    };

    private string GetDurumClass(OdemeDurum durum) => durum switch
    {
        OdemeDurum.Bekliyor => "bg-warning text-dark",
        OdemeDurum.Odendi => "bg-success",
        OdemeDurum.Iptal => "bg-danger",
        OdemeDurum.Ertelendi => "bg-secondary",
        _ => "bg-secondary"
    };

    private string FormatPara(decimal tutar) => $"{tutar:N0} TL";

    private async Task ExcelSablonIndir()
    {
        try
        {
            var excelBytes = BudgetService.GenerateExcelTemplate();
            var fileName = $"OdemeSablonu_{DateTime.Now:yyyyMMdd}.xlsx";
            var base64 = Convert.ToBase64String(excelBytes);
            await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
            ToastService.ShowSuccess("Sablon indirildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
    }

    private async Task ExcelDosyaYukle(InputFileChangeEventArgs e)
    {
        isImporting = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            if (file == null) return;

            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var result = await BudgetService.ImportFromExcelAsync(ms.ToArray());

            if (result.Success && result.ImportedCount > 0)
            {
                ToastService.ShowSuccess($"{result.ImportedCount} odeme yuklendi.");
                ModalKapat();
                await YenileDataAsync();
            }
            else
            {
                var errorMsg = result.Errors.Any() ? string.Join(", ", result.Errors.Take(3)) : "Bilinmeyen hata";
                ToastService.ShowError($"Hata: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Hata: {ex.Message}");
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }
}
