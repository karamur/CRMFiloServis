@page "/ayarlar/lisans-uretici"
@using CRMFiloServis.Web.Services
@inject ILisansService LisansService
@inject IToastService ToastService
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Lisans Üretici</PageTitle>

<div class="row mb-4">
    <div class="col-12">
        <div class="card bg-dark text-white shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1"><i class="bi bi-windows me-2"></i>Masaüstü Lisans Programı</h5>
                    <p class="mb-0 small text-light">Geçmişe dönük lisans kayıtlarını tutmak ve daha gelişmiş özellikler için masaüstü yazılımını indirebilirsiniz.</p>
                </div>
                <a href="/downloads/CRMFiloServisLisans.exe" download class="btn btn-light fw-bold">
                    <i class="bi bi-download me-2"></i>Programı İndir (.exe)
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-key me-2"></i>Yeni Lisans Üret</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Firma Adı *</label>
                    <input type="text" class="form-control" @bind="firmaAdi" placeholder="Müşteri firma adı" />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Yetkili Kişi</label>
                        <input type="text" class="form-control" @bind="yetkili" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Telefon</label>
                        <input type="text" class="form-control" @bind="telefon" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Müşteri Makine Kodu *</label>
                    <input type="text" class="form-control font-monospace" @bind="makineKodu" placeholder="Lisans uygulamasından alınan makine kodu" />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Lisans Tipi</label>
                        <select class="form-select" @bind="lisansTipi">
                            <option value="Trial">Deneme (Trial)</option>
                            <option value="Standard">Standart</option>
                            <option value="Professional">Profesyonel</option>
                            <option value="Enterprise">Kurumsal</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Max Kullanıcı</label>
                        <input type="number" class="form-control" @bind="maxKullanici" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Süre (Ay)</label>
                        <input type="number" class="form-control" @bind="sureAy" />
                    </div>
                </div>

                <div class="d-grid mt-4">
                    <button class="btn btn-primary" @onclick="Uret">
                        <i class="bi bi-gear me-2"></i>Lisans Anahtarı Üret
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-file-earmark-code me-2"></i>Üretilen Anahtar</h5>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(uretilenAnahtar))
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle me-2"></i>Lisans başarıyla üretildi!
                    </div>
                    <textarea class="form-control font-monospace mb-3" rows="8" readonly>@uretilenAnahtar</textarea>

                    <button class="btn btn-outline-success w-100" @onclick="Kopyala">
                        <i class="bi bi-clipboard me-2"></i>Panoya Kopyala
                    </button>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-arrow-left-circle fs-1 mb-3 d-block"></i>
                        <p>Lisans anahtarı üretmek için formu doldurun.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    window.panoyaKopyala = function(text) {
        navigator.clipboard.writeText(text);
    }
</script>

@code {
    private string firmaAdi = "";
    private string yetkili = "";
    private string telefon = "";
    private string makineKodu = "";
    private string lisansTipi = "Standard";
    private int maxKullanici = 10;
    private int sureAy = 12;

    private string uretilenAnahtar = "";
    @inject IJSRuntime JSRuntime

    private void Uret()
    {
        if (string.IsNullOrWhiteSpace(firmaAdi))
        {
            ToastService.ShowWarning("Firma adı zorunludur.");
            return;
        }

        if (string.IsNullOrWhiteSpace(makineKodu) || makineKodu.Length < 16)
        {
            ToastService.ShowWarning("Geçerli bir makine kodu girin (en az 16 karakter).");
            return;
        }

        var bitisTarihi = DateTime.UtcNow.AddMonths(sureAy);

        try
        {
            uretilenAnahtar = LisansService.UretLisansAnahtari(
                firmaAdi, 
                yetkili, 
                "", 
                telefon, 
                lisansTipi, 
                maxKullanici, 
                makineKodu, 
                bitisTarihi);

            ToastService.ShowSuccess("Lisans anahtarı üretildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Hata oluştu: " + ex.Message);
        }
    }

    private async Task Kopyala()
    {
        if (!string.IsNullOrEmpty(uretilenAnahtar))
        {
            await JSRuntime.InvokeVoidAsync("panoyaKopyala", uretilenAnahtar);
            ToastService.ShowInfo("Panoya kopyalandı.");
        }
    }
}
