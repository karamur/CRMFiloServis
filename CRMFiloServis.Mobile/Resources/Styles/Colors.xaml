<?xml version="1.0" encoding="utf-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#1e3c72</Color>
    <Color x:Key="PrimaryLight">#2a5298</Color>
    <Color x:Key="Secondary">#6c757d</Color>
    <Color x:Key="Success">#198754</Color>
    <Color x:Key="Warning">#ffc107</Color>
    <Color x:Key="Danger">#dc3545</Color>
    <Color x:Key="Info">#0dcaf0</Color>
    <Color x:Key="White">#ffffff</Color>
    <Color x:Key="Dark">#212529</Color>
    <Color x:Key="Gray100">#f8f9fa</Color>
    <Color x:Key="Gray200">#e9ecef</Color>
    <Color x:Key="Gray600">#6c757d</Color>

    <Color x:Key="PageBackgroundColor">#f8f9fa</Color>

</ResourceDictionary>
