@page "/profil"
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="mobile-card">
    <div class="text-center mb-3">
        <div style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
            <i class="bi bi-person" style="font-size: 2.5rem; color: white;"></i>
        </div>
        <h3 class="mt-2 mb-1">@AuthService.CurrentUser?.AdSoyad</h3>
        <span class="badge badge-primary">@AuthService.CurrentUser?.Rol?.RolAdi</span>
    </div>

    <ul class="mobile-list">
        <li class="mobile-list-item">
            <div class="icon" style="background: #e3f2fd;">
                <i class="bi bi-person" style="color: #2196f3;"></i>
            </div>
            <div class="content">
                <div class="subtitle">Kullanici Adi</div>
                <div class="title">@AuthService.CurrentUser?.KullaniciAdi</div>
            </div>
        </li>
        @if (!string.IsNullOrEmpty(AuthService.CurrentUser?.Email))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #e8f5e9;">
                    <i class="bi bi-envelope" style="color: #4caf50;"></i>
                </div>
                <div class="content">
                    <div class="subtitle">E-posta</div>
                    <div class="title">@AuthService.CurrentUser.Email</div>
                </div>
            </li>
        }
        @if (!string.IsNullOrEmpty(AuthService.CurrentUser?.Telefon))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #fff3e0;">
                    <i class="bi bi-telephone" style="color: #ff9800;"></i>
                </div>
                <div class="content">
                    <div class="subtitle">Telefon</div>
                    <div class="title">@AuthService.CurrentUser.Telefon</div>
                </div>
            </li>
        }
        <li class="mobile-list-item">
            <div class="icon" style="background: #f3e5f5;">
                <i class="bi bi-clock-history" style="color: #9c27b0;"></i>
            </div>
            <div class="content">
                <div class="subtitle">Son Giris</div>
                <div class="title">@AuthService.CurrentUser?.SonGirisTarihi?.ToString("dd.MM.yyyy HH:mm")</div>
            </div>
        </li>
    </ul>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Ayarlar</h3>
    </div>
    <ul class="mobile-list">
        <li class="mobile-list-item" style="cursor: pointer;" @onclick="GoToServerSettings">
            <div class="icon" style="background: #e8eaf6;">
                <i class="bi bi-gear" style="color: #3f51b5;"></i>
            </div>
            <div class="content">
                <div class="title">Sunucu Ayarlari</div>
                <div class="subtitle">API baglanti ayarlari</div>
            </div>
            <i class="bi bi-chevron-right text-muted"></i>
        </li>
        <li class="mobile-list-item" style="cursor: pointer;">
            <div class="icon" style="background: #e0f2f1;">
                <i class="bi bi-bell" style="color: #009688;"></i>
            </div>
            <div class="content">
                <div class="title">Bildirimler</div>
                <div class="subtitle">Bildirim tercihleri</div>
            </div>
            <i class="bi bi-chevron-right text-muted"></i>
        </li>
    </ul>
</div>

<div class="mobile-card">
    <button class="btn-mobile btn-danger-mobile" @onclick="Logout">
        <i class="bi bi-box-arrow-right"></i>
        <span>Cikis Yap</span>
    </button>
</div>

<div class="text-center mt-3">
    <p class="text-muted" style="font-size: 0.75rem;">
        CRM Filo Servis Mobil v1.0<br/>
        © @DateTime.Now.Year Allbatros Global Teknoloji
    </p>
</div>

@code {
    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void GoToServerSettings()
    {
        // Sunucu ayarlari sayfasina git
    }
}
