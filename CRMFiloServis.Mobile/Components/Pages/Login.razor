@inject IAuthService AuthService
@inject IApiService ApiService

<div class="login-container">
    <div class="login-logo">
        <i class="bi bi-truck"></i>
        <h1>CRM Filo Servis</h1>
        <p>Mobil Uygulama</p>
    </div>

    <div class="login-card">
        @if (showServerConfig)
        {
            <h2><i class="bi bi-gear me-2"></i>Sunucu Ayari</h2>
            <div class="mobile-form-group">
                <label class="mobile-form-label">API Sunucu Adresi</label>
                <input type="text" class="mobile-form-control" @bind="serverUrl" placeholder="http://192.168.1.100:5000" />
            </div>
            <p class="text-muted" style="font-size: 0.8rem;">
                <i class="bi bi-info-circle me-1"></i>
                Ana bilgisayarin IP adresini ve port numarasini girin.
            </p>
            <button class="btn-mobile btn-primary-mobile mt-3" @onclick="SaveServerConfig">
                <i class="bi bi-check-lg"></i> Kaydet ve Devam Et
            </button>
        }
        else
        {
            <h2><i class="bi bi-box-arrow-in-right me-2"></i>Giris Yap</h2>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="background: #f8d7da; color: #842029; padding: 12px; border-radius: 10px; margin-bottom: 15px;">
                    <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                </div>
            }

            <div class="mobile-form-group">
                <label class="mobile-form-label">Kullanici Adi</label>
                <input type="text" class="mobile-form-control" @bind="username" placeholder="Kullanici adiniz" />
            </div>

            <div class="mobile-form-group">
                <label class="mobile-form-label">Sifre</label>
                <input type="password" class="mobile-form-control" @bind="password" placeholder="Sifreniz" />
            </div>

            <button class="btn-mobile btn-primary-mobile" @onclick="LoginAsync" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner" style="width: 20px; height: 20px; border-width: 2px;"></span>
                    <span>Giris Yapiliyor...</span>
                }
                else
                {
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Giris Yap</span>
                }
            </button>

            <div class="text-center mt-3">
                <a href="#" @onclick="ShowServerConfig" @onclick:preventDefault style="color: var(--primary); font-size: 0.85rem;">
                    <i class="bi bi-gear me-1"></i>Sunucu Ayarlari
                </a>
            </div>

            <hr style="margin: 20px 0; border-color: #e9ecef;" />

            <p class="text-center text-muted mb-2" style="font-size: 0.85rem;">Hizli Test Girisi</p>
            <div class="role-grid">
                <div class="role-card" @onclick='() => QuickLogin("admin", "admin123")'>
                    <i class="bi bi-shield-lock role-admin"></i>
                    <div class="role-name">Yonetici</div>
                </div>
                <div class="role-card" @onclick='() => QuickLogin("muhasebe", "muhasebe123")'>
                    <i class="bi bi-calculator role-muhasebe"></i>
                    <div class="role-name">Muhasebe</div>
                </div>
                <div class="role-card" @onclick='() => QuickLogin("operasyon", "operasyon123")'>
                    <i class="bi bi-truck role-operasyon"></i>
                    <div class="role-name">Operasyon</div>
                </div>
                <div class="role-card" @onclick='() => QuickLogin("satis", "satis123")'>
                    <i class="bi bi-graph-up role-satis"></i>
                    <div class="role-name">Satis</div>
                </div>
                <div class="role-card" @onclick='() => QuickLogin("sofor", "sofor123")'>
                    <i class="bi bi-person-badge role-sofor"></i>
                    <div class="role-name">Sofor</div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string serverUrl = "";
    private string? errorMessage;
    private bool isLoading = false;
    private bool showServerConfig = false;

    protected override void OnInitialized()
    {
        serverUrl = Preferences.Get("ApiBaseUrl", "http://192.168.1.100:5000");

        // Sunucu ayari yoksa goster
        if (string.IsNullOrEmpty(Preferences.Get("ApiBaseUrl", "")))
        {
            showServerConfig = true;
        }
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Kullanici adi ve sifre gerekli!";
            return;
        }

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await AuthService.LoginAsync(username, password);
            if (!result.Success)
            {
                errorMessage = result.Message ?? "Giris basarisiz!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Baglanti hatasi: " + ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task QuickLogin(string user, string pass)
    {
        username = user;
        password = pass;
        await LoginAsync();
    }

    private void ShowServerConfig()
    {
        showServerConfig = true;
    }

    private void SaveServerConfig()
    {
        if (!string.IsNullOrWhiteSpace(serverUrl))
        {
            Preferences.Set("ApiBaseUrl", serverUrl);
        }
        showServerConfig = false;
    }
}
