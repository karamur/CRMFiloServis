@page "/"
@inject IAuthService AuthService
@inject IMobileDataService DataService

<div class="mb-3">
    <div class="d-flex align-center justify-between mb-2">
        <span class="text-muted" style="font-size: 0.85rem;">Hosgeldiniz</span>
        <span class="badge badge-primary" style="font-size: 0.75rem;">@AuthService.CurrentUser?.Rol?.RolAdi</span>
    </div>
    <h2 style="font-size: 1.3rem; margin: 0;">@AuthService.CurrentUser?.AdSoyad</h2>
</div>

@if (isLoading)
{
    <div class="text-center mt-4">
        <div class="spinner" style="margin: 0 auto;"></div>
        <p class="text-muted mt-2">Veriler yukleniyor...</p>
    </div>
}
else
{
    <!-- Rol bazli dashboard -->
    @switch (AuthService.CurrentUser?.Rol?.RolAdi)
    {
        case "Admin":
            <AdminDashboard Stats="@stats" />
            break;
        case "Muhasebeci":
            <MuhasebeDashboard Stats="@stats" />
            break;
        case "Operasyon":
            <OperasyonDashboard Stats="@stats" />
            break;
        case "SatisTemsilcisi":
            <SatisDashboard Stats="@stats" />
            break;
        case "SoforRol":
            <SoforDashboard Stats="@stats" />
            break;
        default:
            <GenelDashboard Stats="@stats" />
            break;
    }
}

@code {
    private bool isLoading = true;
    private DashboardStats stats = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            stats = await DataService.GetDashboardStatsAsync();
        }
        catch { }
        finally
        {
            isLoading = false;
        }
    }
}
