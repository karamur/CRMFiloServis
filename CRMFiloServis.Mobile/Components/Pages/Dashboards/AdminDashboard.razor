<!-- Admin Dashboard -->
@using CRMFiloServis.Mobile.Services

<div class="stats-grid">
    <div class="stat-card primary">
        <i class="bi bi-truck text-primary"></i>
        <div class="value">@Stats.ToplamArac</div>
        <div class="label">Toplam Arac</div>
    </div>
    <div class="stat-card success">
        <i class="bi bi-people text-success"></i>
        <div class="value">@Stats.ToplamSofor</div>
        <div class="label">Aktif Sofor</div>
    </div>
    <div class="stat-card warning">
        <i class="bi bi-receipt text-warning"></i>
        <div class="value">@Stats.BekleyenFatura</div>
        <div class="label">Bekleyen Fatura</div>
    </div>
    <div class="stat-card danger">
        <i class="bi bi-exclamation-triangle text-danger"></i>
        <div class="value">@Stats.YaklaţanEvrak</div>
        <div class="label">Yaklasan Evrak</div>
    </div>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Hizli Islemler</h3>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;">
        <a href="/araclar" class="text-center p-2" style="text-decoration: none;">
            <div style="background: #e3f2fd; padding: 12px; border-radius: 10px;">
                <i class="bi bi-truck text-primary" style="font-size: 1.5rem;"></i>
            </div>
            <div style="font-size: 0.75rem; margin-top: 5px; color: var(--dark);">Araclar</div>
        </a>
        <a href="/soforler" class="text-center p-2" style="text-decoration: none;">
            <div style="background: #e8f5e9; padding: 12px; border-radius: 10px;">
                <i class="bi bi-person-badge text-success" style="font-size: 1.5rem;"></i>
            </div>
            <div style="font-size: 0.75rem; margin-top: 5px; color: var(--dark);">Soforler</div>
        </a>
        <a href="/faturalar" class="text-center p-2" style="text-decoration: none;">
            <div style="background: #fff3e0; padding: 12px; border-radius: 10px;">
                <i class="bi bi-receipt text-warning" style="font-size: 1.5rem;"></i>
            </div>
            <div style="font-size: 0.75rem; margin-top: 5px; color: var(--dark);">Faturalar</div>
        </a>
    </div>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Son Islemler</h3>
        <a href="/aktiviteler" style="font-size: 0.85rem; color: var(--primary);">Tumu</a>
    </div>
    <ul class="mobile-list">
        @foreach (var item in Stats.SonIslemler.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: @GetIconBg(item.Tip);">
                    <i class="bi @GetIcon(item.Tip)" style="color: @GetIconColor(item.Tip);"></i>
                </div>
                <div class="content">
                    <div class="title">@item.Baslik</div>
                    <div class="subtitle">@item.Tarih.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter]
    public DashboardStats Stats { get; set; } = new();

    private string GetIcon(string tip) => tip switch
    {
        "fatura" => "bi-receipt",
        "arac" => "bi-truck",
        "sofor" => "bi-person-badge",
        "masraf" => "bi-cash",
        _ => "bi-circle"
    };

    private string GetIconBg(string tip) => tip switch
    {
        "fatura" => "#fff3e0",
        "arac" => "#e3f2fd",
        "sofor" => "#e8f5e9",
        "masraf" => "#fce4ec",
        _ => "#f5f5f5"
    };

    private string GetIconColor(string tip) => tip switch
    {
        "fatura" => "#ff9800",
        "arac" => "#2196f3",
        "sofor" => "#4caf50",
        "masraf" => "#e91e63",
        _ => "#9e9e9e"
    };
}
