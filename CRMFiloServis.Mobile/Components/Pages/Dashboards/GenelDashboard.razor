<!-- Genel Kullanici Dashboard -->
@using CRMFiloServis.Mobile.Services

<div class="text-center mb-4">
    <i class="bi bi-person-circle" style="font-size: 4rem; color: var(--primary);"></i>
    <h3 class="mt-2">Hosgeldiniz!</h3>
    <p class="text-muted">Yetkinize gore menuler asagida gorunmektedir.</p>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Kullanilabilir Moduller</h3>
    </div>
    <ul class="mobile-list">
        <li class="mobile-list-item">
            <div class="icon" style="background: #e3f2fd;">
                <i class="bi bi-eye" style="color: #2196f3;"></i>
            </div>
            <div class="content">
                <div class="title">Goruntuleme</div>
                <div class="subtitle">Temel verileri goruntuleme yetkisi</div>
            </div>
        </li>
        <li class="mobile-list-item">
            <div class="icon" style="background: #e8f5e9;">
                <i class="bi bi-person-circle" style="color: #4caf50;"></i>
            </div>
            <div class="content">
                <div class="title">Profil</div>
                <div class="subtitle">Profil bilgilerini duzenleme</div>
            </div>
        </li>
    </ul>
</div>

<div class="mobile-card">
    <p class="text-muted text-center" style="font-size: 0.85rem;">
        Daha fazla yetki icin sistem yoneticinizle iletisime gecin.
    </p>
</div>

@code {
    [Parameter]
    public DashboardStats Stats { get; set; } = new();
}
