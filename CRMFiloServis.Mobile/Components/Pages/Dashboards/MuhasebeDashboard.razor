<!-- Muhasebe Dashboard -->
@using CRMFiloServis.Mobile.Services

<div class="stats-grid">
    <div class="stat-card success">
        <i class="bi bi-arrow-down-circle text-success"></i>
        <div class="value">@Stats.AylikGelir.ToString("N0")</div>
        <div class="label">Aylik Gelir (?)</div>
    </div>
    <div class="stat-card danger">
        <i class="bi bi-arrow-up-circle text-danger"></i>
        <div class="value">@Stats.AylikGider.ToString("N0")</div>
        <div class="label">Aylik Gider (?)</div>
    </div>
    <div class="stat-card warning">
        <i class="bi bi-receipt text-warning"></i>
        <div class="value">@Stats.BekleyenFatura</div>
        <div class="label">Bekleyen Fatura</div>
    </div>
    <div class="stat-card primary">
        <i class="bi bi-bank text-primary"></i>
        <div class="value">@Stats.BankaBakiye.ToString("N0")</div>
        <div class="label">Banka Bakiye (?)</div>
    </div>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Odenmemis Faturalar</h3>
        <span class="badge badge-warning">@Stats.OdenmemisFaturalar.Count</span>
    </div>
    <ul class="mobile-list">
        @foreach (var fatura in Stats.OdenmemisFaturalar.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #fff3e0;">
                    <i class="bi bi-receipt" style="color: #ff9800;"></i>
                </div>
                <div class="content">
                    <div class="title">@fatura.CariUnvan</div>
                    <div class="subtitle">@fatura.FaturaNo - @fatura.Tarih.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="badge badge-danger">@fatura.Tutar.ToString("N0") ?</div>
            </li>
        }
    </ul>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Bu Ayki Masraflar</h3>
    </div>
    <ul class="mobile-list">
        @foreach (var masraf in Stats.SonMasraflar.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #fce4ec;">
                    <i class="bi bi-cash" style="color: #e91e63;"></i>
                </div>
                <div class="content">
                    <div class="title">@masraf.Aciklama</div>
                    <div class="subtitle">@masraf.Tarih.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="badge badge-info">@masraf.Tutar.ToString("N0") ?</div>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter]
    public DashboardStats Stats { get; set; } = new();
}
