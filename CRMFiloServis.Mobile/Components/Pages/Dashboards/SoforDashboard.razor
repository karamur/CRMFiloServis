<!-- Sofor Dashboard -->
@using CRMFiloServis.Mobile.Services

<div class="mobile-card" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); color: white;">
    <div class="d-flex align-center gap-2 mb-3">
        <i class="bi bi-truck" style="font-size: 2rem;"></i>
        <div>
            <div style="font-size: 0.85rem; opacity: 0.8;">Aracim</div>
            <div style="font-size: 1.2rem; font-weight: 600;">@Stats.SoforArac?.Plaka</div>
        </div>
    </div>
    <div class="d-flex justify-between">
        <div>
            <div style="font-size: 0.75rem; opacity: 0.8;">Marka/Model</div>
            <div style="font-weight: 500;">@Stats.SoforArac?.MarkaModel</div>
        </div>
        <div>
            <div style="font-size: 0.75rem; opacity: 0.8;">Kilometre</div>
            <div style="font-weight: 500;">@Stats.SoforArac?.Kilometre.ToString("N0") km</div>
        </div>
    </div>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Bugunku Guzergahim</h3>
    </div>
    @if (Stats.BugunGuzergah != null)
    {
        <div style="background: #f8f9fa; padding: 15px; border-radius: 10px;">
            <div class="d-flex align-center gap-2 mb-2">
                <i class="bi bi-geo-alt text-primary"></i>
                <span style="font-weight: 500;">@Stats.BugunGuzergah.BaslangicNoktasi</span>
            </div>
            <div style="border-left: 2px dashed #dee2e6; margin-left: 10px; padding-left: 15px; padding: 10px 0 10px 15px;">
                <span class="text-muted" style="font-size: 0.85rem;">@Stats.BugunGuzergah.Mesafe km</span>
            </div>
            <div class="d-flex align-center gap-2">
                <i class="bi bi-geo-alt-fill text-success"></i>
                <span style="font-weight: 500;">@Stats.BugunGuzergah.BitisNoktasi</span>
            </div>
        </div>
        <div class="d-flex justify-between mt-3">
            <span class="text-muted" style="font-size: 0.85rem;">
                <i class="bi bi-clock me-1"></i>@Stats.BugunGuzergah.BaslamaSaati
            </span>
            <span class="badge @GetDurumBadge(Stats.BugunGuzergah.Durum)">@Stats.BugunGuzergah.Durum</span>
        </div>
    }
    else
    {
        <div class="text-center text-muted p-3">
            <i class="bi bi-calendar-x" style="font-size: 2rem;"></i>
            <p class="mt-2 mb-0">Bugun icin guzergah atanmamis</p>
        </div>
    }
</div>

<div class="stats-grid">
    <div class="stat-card primary">
        <i class="bi bi-signpost-split text-primary"></i>
        <div class="value">@Stats.AylikGuzergah</div>
        <div class="label">Bu Ay Guzergah</div>
    </div>
    <div class="stat-card success">
        <i class="bi bi-speedometer2 text-success"></i>
        <div class="value">@Stats.AylikKm.ToString("N0")</div>
        <div class="label">Bu Ay Km</div>
    </div>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Masraf Girisi</h3>
    </div>
    <button class="btn-mobile btn-outline-mobile">
        <i class="bi bi-plus-circle"></i>
        <span>Yeni Masraf Ekle</span>
    </button>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Son Masraflarim</h3>
    </div>
    <ul class="mobile-list">
        @foreach (var masraf in Stats.SoforMasraflari.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #fce4ec;">
                    <i class="bi @GetMasrafIcon(masraf.Tip)" style="color: #e91e63;"></i>
                </div>
                <div class="content">
                    <div class="title">@masraf.Tip</div>
                    <div class="subtitle">@masraf.Tarih.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="badge badge-info">@masraf.Tutar.ToString("N0") ?</div>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter]
    public DashboardStats Stats { get; set; } = new();

    private string GetDurumBadge(string durum) => durum switch
    {
        "Tamamlandi" => "badge-success",
        "Devam Ediyor" => "badge-warning",
        "Bekliyor" => "badge-info",
        _ => "badge-secondary"
    };

    private string GetMasrafIcon(string tip) => tip switch
    {
        "Yakit" => "bi-fuel-pump",
        "Otopark" => "bi-p-square",
        "Yemek" => "bi-cup-hot",
        "Bakim" => "bi-tools",
        _ => "bi-cash"
    };
}
