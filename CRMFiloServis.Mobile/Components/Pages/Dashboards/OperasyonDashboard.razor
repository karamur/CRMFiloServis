<!-- Operasyon Dashboard -->
@using CRMFiloServis.Mobile.Services

<div class="stats-grid">
    <div class="stat-card primary">
        <i class="bi bi-truck text-primary"></i>
        <div class="value">@Stats.AktifArac</div>
        <div class="label">Aktif Arac</div>
    </div>
    <div class="stat-card success">
        <i class="bi bi-person-badge text-success"></i>
        <div class="value">@Stats.ToplamSofor</div>
        <div class="label">Calisan Sofor</div>
    </div>
    <div class="stat-card warning">
        <i class="bi bi-tools text-warning"></i>
        <div class="value">@Stats.ServistekiArac</div>
        <div class="label">Serviste</div>
    </div>
    <div class="stat-card danger">
        <i class="bi bi-exclamation-triangle text-danger"></i>
        <div class="value">@Stats.YaklaţanEvrak</div>
        <div class="label">Yaklasan Evrak</div>
    </div>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Gunun Guzergahlari</h3>
        <span class="badge badge-primary">@Stats.GununGuzergahlari.Count</span>
    </div>
    <ul class="mobile-list">
        @foreach (var guzergah in Stats.GununGuzergahlari.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #e3f2fd;">
                    <i class="bi bi-signpost-split" style="color: #2196f3;"></i>
                </div>
                <div class="content">
                    <div class="title">@guzergah.GuzergahAdi</div>
                    <div class="subtitle">@guzergah.SoforAdi - @guzergah.Plaka</div>
                </div>
                <div class="badge @GetDurumBadge(guzergah.Durum)">@guzergah.Durum</div>
            </li>
        }
    </ul>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Evrak Uyarilari</h3>
    </div>
    <ul class="mobile-list">
        @foreach (var evrak in Stats.EvrakUyarilari.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #ffebee;">
                    <i class="bi bi-file-earmark-text" style="color: #f44336;"></i>
                </div>
                <div class="content">
                    <div class="title">@evrak.EvrakTipi</div>
                    <div class="subtitle">@evrak.Plaka - @evrak.BitisTarihi.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="badge badge-danger">@evrak.KalanGun gun</div>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter]
    public DashboardStats Stats { get; set; } = new();

    private string GetDurumBadge(string durum) => durum switch
    {
        "Tamamlandi" => "badge-success",
        "Devam Ediyor" => "badge-warning",
        "Bekliyor" => "badge-info",
        _ => "badge-secondary"
    };
}
