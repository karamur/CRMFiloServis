<!-- Satis Dashboard -->
@using CRMFiloServis.Mobile.Services

<div class="stats-grid">
    <div class="stat-card success">
        <i class="bi bi-graph-up text-success"></i>
        <div class="value">@Stats.AylikSatis</div>
        <div class="label">Aylik Satis</div>
    </div>
    <div class="stat-card primary">
        <i class="bi bi-car-front text-primary"></i>
        <div class="value">@Stats.AktifIlan</div>
        <div class="label">Aktif Ilan</div>
    </div>
    <div class="stat-card warning">
        <i class="bi bi-clock-history text-warning"></i>
        <div class="value">@Stats.BekleyenTeklif</div>
        <div class="label">Bekleyen Teklif</div>
    </div>
    <div class="stat-card info">
        <i class="bi bi-people text-info"></i>
        <div class="value">@Stats.PotansiyelMusteri</div>
        <div class="label">Potansiyel Musteri</div>
    </div>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Son Satislar</h3>
    </div>
    <ul class="mobile-list">
        @foreach (var satis in Stats.SonSatislar.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #e8f5e9;">
                    <i class="bi bi-car-front" style="color: #4caf50;"></i>
                </div>
                <div class="content">
                    <div class="title">@satis.AracBilgi</div>
                    <div class="subtitle">@satis.MusteriBilgi - @satis.Tarih.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="badge badge-success">@satis.Tutar.ToString("N0") ?</div>
            </li>
        }
    </ul>
</div>

<div class="mobile-card">
    <div class="mobile-card-header">
        <h3 class="mobile-card-title">Piyasa Firsatlari</h3>
    </div>
    <ul class="mobile-list">
        @foreach (var firsat in Stats.PiyasaFirsatlari.Take(5))
        {
            <li class="mobile-list-item">
                <div class="icon" style="background: #fff3e0;">
                    <i class="bi bi-search" style="color: #ff9800;"></i>
                </div>
                <div class="content">
                    <div class="title">@firsat.AracBilgi</div>
                    <div class="subtitle">@firsat.Kaynak - @firsat.Fiyat.ToString("N0") ?</div>
                </div>
                <div class="badge badge-warning">%@firsat.IndirimOrani</div>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter]
    public DashboardStats Stats { get; set; } = new();
}
