@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation

@if (!AuthService.IsAuthenticated)
{
    <Login />
}
else
{
    <div class="app-container">
        <!-- Header -->
        <header class="app-header">
            <div>
                <h1>@GetPageTitle()</h1>
            </div>
            <div class="user-info">
                <span style="font-size: 0.85rem;">@AuthService.CurrentUser?.AdSoyad</span>
                <div class="avatar">
                    <i class="bi bi-person"></i>
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="app-content" style="padding-bottom: 70px;">
            @Body
        </main>

        <!-- Bottom Navigation -->
        <nav class="bottom-nav">
            @foreach (var item in GetNavItems())
            {
                <a href="@item.Href" class="nav-item @(IsActive(item.Href) ? "active" : "")">
                    <i class="bi @item.Icon"></i>
                    <span>@item.Label</span>
                </a>
            }
        </nav>
    </div>
}

@code {
    private string currentUrl = "/";

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        currentUrl = Navigation.Uri;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = e.Location;
        StateHasChanged();
    }

    private bool IsActive(string href)
    {
        var path = new Uri(currentUrl).AbsolutePath;
        if (href == "/") return path == "/";
        return path.StartsWith(href);
    }

    private string GetPageTitle()
    {
        var path = new Uri(currentUrl).AbsolutePath;
        return path switch
        {
            "/" => "Ana Sayfa",
            "/araclar" => "Araclar",
            "/guzergahlar" => "Guzergahlar",
            "/faturalar" => "Faturalar",
            "/masraflar" => "Masraflar",
            "/profil" => "Profil",
            "/ayarlar" => "Ayarlar",
            _ => "CRM Filo"
        };
    }

    private List<NavItem> GetNavItems()
    {
        var role = AuthService.CurrentUser?.Rol?.RolAdi ?? "";
        var items = new List<NavItem>();

        // Ana sayfa herkes icin
        items.Add(new NavItem("/", "bi-house-fill", "Ana Sayfa"));

        // Role gore menuler
        switch (role)
        {
            case "Admin":
                items.Add(new NavItem("/araclar", "bi-truck", "Araclar"));
                items.Add(new NavItem("/faturalar", "bi-receipt", "Faturalar"));
                items.Add(new NavItem("/masraflar", "bi-cash-stack", "Masraflar"));
                items.Add(new NavItem("/profil", "bi-person-circle", "Profil"));
                break;

            case "Muhasebeci":
                items.Add(new NavItem("/faturalar", "bi-receipt", "Faturalar"));
                items.Add(new NavItem("/masraflar", "bi-cash-stack", "Masraflar"));
                items.Add(new NavItem("/banka", "bi-bank", "Banka"));
                items.Add(new NavItem("/profil", "bi-person-circle", "Profil"));
                break;

            case "Operasyon":
                items.Add(new NavItem("/araclar", "bi-truck", "Araclar"));
                items.Add(new NavItem("/guzergahlar", "bi-signpost-split", "Guzergah"));
                items.Add(new NavItem("/servisler", "bi-tools", "Servisler"));
                items.Add(new NavItem("/profil", "bi-person-circle", "Profil"));
                break;

            case "SatisTemsilcisi":
                items.Add(new NavItem("/satis", "bi-graph-up", "Satis"));
                items.Add(new NavItem("/piyasa", "bi-search", "Piyasa"));
                items.Add(new NavItem("/musteriler", "bi-people", "Musteriler"));
                items.Add(new NavItem("/profil", "bi-person-circle", "Profil"));
                break;

            case "SoforRol":
                items.Add(new NavItem("/guzergahlarim", "bi-signpost-split", "Guzergah"));
                items.Add(new NavItem("/aracim", "bi-truck", "Aracim"));
                items.Add(new NavItem("/masraflarim", "bi-cash", "Masraflar"));
                items.Add(new NavItem("/profil", "bi-person-circle", "Profil"));
                break;

            default:
                items.Add(new NavItem("/profil", "bi-person-circle", "Profil"));
                break;
        }

        return items;
    }

    private class NavItem
    {
        public string Href { get; }
        public string Icon { get; }
        public string Label { get; }

        public NavItem(string href, string icon, string label)
        {
            Href = href;
            Icon = icon;
            Label = label;
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
